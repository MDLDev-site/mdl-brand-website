# MDL Brand Website — Environment Variables
# Copy this file to .env and update values to match your local setup.

# Project paths
MDL_BRAND_WEBSITE_PATH=~/Projects/mdl-brand-website
MDL_BRAND_SITE_CMS_PATH=~/Projects/mdl-brand-site-cms

# GitNexus - MDL Repo Local Paths
MDL_BASELINE_PATH=~/Projects/mdl-baseline
MDL_ADMIN_DEV_PATH=~/Projects/mdl-admin-dev
MDL_FAN_DEV_PATH=~/Projects/mdl-fan-dev
MDL_LAMBDAS_PATH=~/Projects/mdl-lambdas
MDL_RESEARCH_STREAM_DEPLOY_PATH=~/Projects/mdl-research-stream-deploy

# Docs-RAG MCP Server
DOCS_PATH=./Docs

# AWS (optional — for Lambda development)
