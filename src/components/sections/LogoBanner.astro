---
import type { LogoBannerSection } from '../../types/content';

interface Props {
  section: LogoBannerSection;
}

const { section } = Astro.props;
---

<section class="bg-grey" aria-label="Trusted partners">
  <div class="mx-auto flex max-w-360 flex-col items-center gap-[32px] px-[24px] pt-[24px] pb-[64px] md:px-30">
    <h4 class="text-h4 text-center text-charcoal-pitch">
      {section.heading}
    </h4>

    {/* Mobile: 4-per-row flex-wrap so logos read at a proper size and the
        overflow row (7 logos -> 4+3) sits centered (DEV-2221).
        Desktop: keep the existing inline strip. */}
    <ul class="flex flex-wrap items-center justify-center gap-y-[24px] md:gap-10" role="list">
      {section.logos.map((logo) => (
        <li class="flex basis-1/4 items-center justify-center px-[8px] md:basis-auto md:px-0">
          {logo.src ? (
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-14 w-auto max-w-full object-contain md:h-15 md:max-w-30"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div
              class="flex h-14 w-14 items-center justify-center rounded-sm bg-charcoal-pitch/10 md:h-15 md:w-15"
              role="img"
              aria-label={logo.alt}
            >
              <span class="font-body text-[10px] text-charcoal-pitch/40">Logo</span>
            </div>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
