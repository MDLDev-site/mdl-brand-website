---
import type { LogoBannerSection } from '../../types/content';

interface Props {
  section: LogoBannerSection;
}

const { section } = Astro.props;
---

<section class="bg-grey" aria-label="Trusted partners">
  <div class="mx-auto flex max-w-[1440px] flex-col items-center gap-[32px] px-[24px] pt-[24px] pb-[64px] md:px-[120px]">
    <h4 class="text-center font-heading text-[20px] font-medium uppercase leading-[0.9] tracking-[-1px] text-charcoal-pitch md:font-subheading md:text-[24px] md:tracking-[-0.96px]">
      {section.heading}
    </h4>

    <ul class="grid grid-cols-4 items-center justify-items-center gap-x-[16px] gap-y-[24px] md:flex md:flex-wrap md:justify-center md:gap-[40px]" role="list">
      {section.logos.map((logo) => (
        <li class="flex items-center justify-center">
          {logo.src ? (
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-[40px] w-auto max-w-[80px] object-contain md:h-[60px] md:max-w-[120px]"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <div
              class="flex h-[40px] w-[40px] items-center justify-center rounded-[4px] bg-charcoal-pitch/10 md:h-[60px] md:w-[60px]"
              role="img"
              aria-label={logo.alt}
            >
              <span class="font-body text-[10px] text-charcoal-pitch/40">Logo</span>
            </div>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
