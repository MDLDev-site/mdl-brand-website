---
import type { PricingTier, PricingProductId } from '../../types/content';

interface Props {
  tier: PricingTier;
  productId: PricingProductId;
  tierIndex: number;
}

const { tier, productId, tierIndex } = Astro.props;

const productAccentClass = productId === 'on-demand'
  ? 'bg-blue-matchday text-white hover:bg-blue-matchday/90'
  : 'bg-orange-basketball text-white hover:bg-orange-basketball/90';

const buttonClass =
  tier.buttonVariant === 'orange'
    ? 'bg-orange-basketball text-white hover:bg-orange-basketball/90'
    : tier.buttonVariant === 'blue'
      ? 'bg-blue-matchday text-white hover:bg-blue-matchday/90'
      : tier.buttonVariant === 'product-accent'
        ? productAccentClass
        : 'bg-white/10 text-white hover:bg-white/20';

const productRingClass = productId === 'on-demand'
  ? 'ring-blue-matchday'
  : 'ring-orange-basketball';

// Most Popular gets a product-coloured ring; recommended (set dynamically by
// the calculator) takes the same product-colour ring via the JS-applied class.
const ringClass = tier.tag?.variant === 'most-popular'
  ? `ring-1 ${productRingClass}`
  : 'ring-1 ring-white/10';

const popularTagClass = productId === 'on-demand'
  ? 'bg-blue-matchday text-white'
  : 'bg-orange-basketball text-white';
---

<div
  class={`pricing-plan-card relative flex flex-col rounded-[16px] bg-charcoal-pitch px-[16px] pb-[20px] pt-[28px] ${ringClass}`}
  data-product={productId}
  data-tier={tier.id}
  data-tier-index={tierIndex}
>
  {/* Most Popular badge — static from YAML, hidden when the calculator
      replaces it with the dynamic Recommended badge */}
  {tier.tag?.variant === 'most-popular' && (
    <span
      class={`pricing-tag-popular absolute -top-[12px] left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full px-[12px] py-[4px] text-body font-medium tracking-[0.24px] ${popularTagClass}`}
    >
      {tier.tag.label}
    </span>
  )}

  {/* Recommended badge — present on every card, hidden by default. The
      calculator's recompute() reveals the one matching the recommended
      tier and hides all .pricing-tag-popular badges. */}
  <span
    class={`pricing-tag-recommended hidden absolute -top-[12px] left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full px-[12px] py-[4px] text-body font-medium tracking-[0.24px] ${popularTagClass}`}
  >
    Recommended
  </span>

  {/* Header: name + price + VAT text — all stacked centered so price
      baselines align across cards regardless of VAT-text length. */}
  <div class="flex flex-col items-center gap-[4px] text-center">
    <p class="text-h5 text-white">
      {tier.name}
    </p>
    <span
      class="pricing-price font-heading text-[40px] font-medium leading-none text-white"
      data-monthly={tier.monthlyPrice}
      data-annual={tier.annualPrice}
    >
      {tier.monthlyPrice}
    </span>
    <span class="flex items-baseline justify-center gap-[6px] text-note font-medium text-white/60">
      <span
        class="pricing-price-strike line-through"
        data-monthly-strike={tier.annualPrice}
        data-annual-strike={tier.monthlyPrice}
      >{tier.annualPrice}</span>
      <span
        class="pricing-price-vat"
        data-monthly-vat="P/M Excl. VAT"
        data-annual-vat="P/M Annually Excl. VAT"
      >
        P/M Excl. VAT
      </span>
    </span>
  </div>

  <a
    href={tier.cta.link}
    class={`mt-[20px] inline-flex w-full items-center justify-center rounded-sm px-[24px] py-[12px] text-body font-medium transition-colors ${buttonClass}`}
  >
    {tier.cta.text}
  </a>

  {tier.description && (
    <p class="mt-[12px] text-body text-white/60 text-center">
      {tier.description}
    </p>
  )}

  {/* Differentiator points — Live Stream Hours / Bandwidth / Storage */}
  {tier.differentiators && tier.differentiators.length > 0 && (
    <ul class="mt-[16px] flex flex-col gap-[6px] border-t border-white/10 pt-[16px]" role="list">
      {tier.differentiators.map((d) => (
        <li class="flex items-baseline justify-between gap-[8px] text-body">
          <span class="text-white/60">{d.label}:</span>
          <span class="text-right font-medium text-white">{d.value}</span>
        </li>
      ))}
    </ul>
  )}
</div>
