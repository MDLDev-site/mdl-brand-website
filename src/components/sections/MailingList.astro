---
import type { MailingListSection } from '../../types/content';

interface Props {
  section: MailingListSection;
}

const { section } = Astro.props;
---

<section class="bg-white" aria-label="Newsletter signup">
  <div class="mx-auto flex max-w-[1440px] flex-col items-center gap-[24px] px-[24px] py-[64px] text-center md:px-[120px] md:py-[80px]">
    <h4 class="font-heading-semi text-[24px] font-medium uppercase leading-none tracking-[-0.96px] text-charcoal-pitch md:text-[32px]">
      {section.heading}
    </h4>

    {section.description && (
      <p class="max-w-[480px] font-body text-[14px] font-normal leading-[1.5] text-text-primary">
        {section.description}
      </p>
    )}

    <form
      class="flex w-full max-w-[500px] flex-col gap-[12px] pt-[8px] sm:flex-row sm:gap-0"
      data-mailing-list-form
    >
      <label for="mailing-list-email" class="sr-only">Email address</label>
      <input
        id="mailing-list-email"
        type="email"
        name="email"
        required
        placeholder={section.placeholder}
        class="flex-1 rounded-[4px] border border-charcoal-pitch/20 px-[16px] py-[14px] font-body text-[14px] text-charcoal-pitch placeholder:text-charcoal-pitch/40 focus:border-blue-matchday focus:outline-none focus:ring-1 focus:ring-blue-matchday sm:rounded-r-none sm:border-r-0"
        autocomplete="email"
      />
      <button
        type="submit"
        class="rounded-[4px] bg-blue-matchday px-[24px] py-[14px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-white transition-colors hover:bg-blue-matchday/90 sm:rounded-l-none"
      >
        {section.buttonText}
      </button>
    </form>
  </div>
</section>
