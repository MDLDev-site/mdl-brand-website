---
import type { FeatureCategory } from '../../types/content';

interface Props {
  category: FeatureCategory;
}

const { category } = Astro.props;
const bgClass = category.background === 'grey' ? 'bg-grey' : 'bg-white';
---

{category.features.length > 0 && (
  <section id={category.id} class={`${bgClass} overflow-hidden py-[64px] md:py-30`}>
    <div class="mx-auto max-w-360 px-[24px] md:px-30">
      {/* Section header — can be hidden per category via hideHeading */}
      {!category.hideHeading && (
        <div class="mb-[48px] md:mb-25">
          <h2 class="text-h3 text-charcoal-pitch">
            {category.heading}
          </h2>
          <p class="mt-[16px] max-w-147.5 text-body-lg text-text-primary">
            {category.description}
          </p>
        </div>
      )}

      {/* Feature row list — 3 columns per row per DEV-2291:
          Feature name | Description | Content (bullets/image/empty).
          On mobile the columns stack. Mobile spacing tightened per
          DEV-2303/2341 — 16px top/bottom on each row gives the 32px
          between features Natalia requested. */}
      <div class="flex flex-col">
        {category.features.map((feature) => (
          <div class="grid grid-cols-1 gap-[12px] border-b border-[rgba(21,38,68,0.1)] py-[16px] md:grid-cols-[minmax(0,1fr)_minmax(0,1.5fr)_minmax(0,1.5fr)] md:items-start md:gap-13 md:py-[20px]">
            {/* Col 1 — feature name */}
            <h3 class="text-h4 text-charcoal-pitch">
              {feature.title}
            </h3>

            {/* Col 2 — description */}
            <div class="min-w-0 text-body text-text-primary">
              <Fragment set:html={feature.description
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\n\n/g, '<br><br>')
                .replace(/\n- /g, '<br>• ')
              } />
            </div>

            {/* Col 3 — content (bullets, image, or empty) */}
            <div class="min-w-0">
              {feature.checks && feature.checks.length > 0 && (
                <div class="flex flex-col gap-[8px]">
                  {feature.checks.map((check) => (
                    <div class="flex items-center gap-[16px]">
                      <div class="flex h-[32px] w-[32px] shrink-0 items-center justify-center rounded-full bg-yellow-tennis">
                        <svg class="h-3.5 w-3.5 text-charcoal-pitch" viewBox="0 0 16 16" fill="none">
                          <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </div>
                      <span class="text-body text-text-primary">
                        {check}
                      </span>
                    </div>
                  ))}
                </div>
              )}

              {feature.image && (
                <div class="flex justify-center overflow-hidden rounded-md">
                  {/* Image enlarged and centred per DEV-2304 — let it fill
                      the column up to a wider cap so it carries the row
                      visually. */}
                  <img
                    src={feature.image}
                    alt={feature.title}
                    class="h-auto w-full object-contain object-center"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{/* Empty sections get a minimal anchor target only */}
{category.features.length === 0 && (
  <div id={category.id}></div>
)}
