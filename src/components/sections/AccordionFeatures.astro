---
import type { AccordionFeaturesSection } from '../../types/content';

interface Props {
  section: AccordionFeaturesSection;
}

const { section } = Astro.props;
---

<section class="bg-navy-umpire" aria-label={section.heading.join(' ')}>
  <div class="mx-auto flex max-w-360 flex-col gap-[64px] px-[24px] py-20 md:gap-25 md:p-30">
    {/* Top: heading */}
    <h2 class="max-w-200 font-heading text-[50px] font-medium uppercase leading-[0.9] tracking-[-1px] text-white md:text-[80px] md:tracking-[1px]">
      {section.heading.map((line) => (
        <span class="block">{line}</span>
      ))}
    </h2>

    {/* Stats row — 2x2 grid on mobile, single row on desktop */}
    <div class="grid grid-cols-2 gap-[24px] md:flex md:gap-[64px]">
      {section.stats.map((stat) => (
        <div class="flex items-stretch gap-[12px] md:gap-[16px]">
          <div class="w-[4px] shrink-0 rounded-full bg-yellow-tennis md:w-[8px]" aria-hidden="true"></div>
          <div class="flex flex-col gap-[4px]">
            <span class="font-heading text-[28px] font-medium uppercase leading-[1.15] tracking-[-0.5px] text-white md:text-[50px]">
              {stat.value}
            </span>
            <span class="font-body text-[12px] font-normal leading-[1.4] text-white/60 md:text-[14px]">
              {stat.label}
            </span>
          </div>
        </div>
      ))}
    </div>

    {/* Buttons */}
    <div class="flex flex-col gap-[16px] sm:flex-row sm:items-center sm:gap-[24px]">
      <a
        href={section.cta.primary.link}
        class="inline-flex w-full items-center justify-center rounded-sm bg-blue-matchday px-[32px] py-[16px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[2px] text-white transition-colors hover:bg-blue-matchday/90 sm:w-auto"
      >
        {section.cta.primary.text}
      </a>

      <a
        href={section.cta.secondary.link}
        class="group inline-flex items-center justify-center gap-[8px] py-[8px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-white transition-colors hover:text-yellow-tennis"
      >
        {section.cta.secondary.text}
        <svg
          class="h-[16px] w-[16px] transition-transform group-hover:translate-x-[4px]"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    {/* Bottom: accordion + illustration */}
    <div class="flex flex-col gap-[48px] md:flex-row md:gap-[64px]">
      {/* Accordion */}
      <div class="flex-1">
        <div class="accordion border-l-8 border-white/20">
          {section.items.map((item, index) => (
            <div
              class:list={[
                'accordion-item border-l-8 -ml-[8px] transition-colors',
                item.expanded ? 'border-yellow-tennis' : 'border-transparent',
              ]}
              data-expanded={item.expanded ? 'true' : 'false'}
            >
              <button
                class="flex w-full items-center py-5 pl-[24px] pr-[16px] text-left"
                type="button"
                aria-expanded={item.expanded ? 'true' : 'false'}
                aria-controls={`accordion-panel-${index}`}
              >
                <h4 class="font-heading-semi text-[24px] font-medium uppercase leading-none tracking-[-0.96px] text-white md:text-[32px]">
                  {item.title}
                </h4>
              </button>

              <div
                id={`accordion-panel-${index}`}
                class:list={[
                  'accordion-panel overflow-hidden transition-all duration-300',
                  item.expanded ? 'max-h-75 opacity-100' : 'max-h-0 opacity-0',
                ]}
                role="region"
              >
                <div class="flex flex-col gap-[16px] pb-[24px] pl-[24px] pr-[16px]">
                  {item.description && (
                    <p class="font-body text-[14px] font-normal leading-normal text-white/60">
                      {item.description}
                    </p>
                  )}
                  {item.learnMoreLink && (
                    <a
                      href={item.learnMoreLink}
                      class="inline-flex items-center gap-[4px] font-body text-[14px] font-medium text-yellow-tennis transition-colors hover:text-yellow-tennis/80"
                    >
                      Learn more
                      <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Illustration area */}
      <div class="hidden flex-1 items-center justify-center md:flex">
        <div class="relative h-125 w-full rounded-[16px] overflow-hidden">
          {[
            '/images/accordion/drm.png',
            '/images/accordion/stripe.png',
            '/images/accordion/support.png',
            '/images/accordion/scale.png',
            '/images/accordion/cdn.png',
            '/images/accordion/gdpr.png',
          ].map((src, i) => {
            const expandedIndex = section.items.findIndex(item => item.expanded);
            const defaultActive = expandedIndex >= 0 ? expandedIndex : 0;
            return (
              <img
                src={src}
                alt={section.items[i]?.title || ''}
                class:list={[
                  'accordion-illustration absolute inset-0 h-full w-full object-contain transition-opacity duration-300',
                  i === defaultActive ? 'opacity-100' : 'opacity-0',
                ]}
                data-illustration-index={i}
                loading="lazy"
                decoding="async"
              />
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initAccordions() {
    const accordions = document.querySelectorAll('.accordion');

    accordions.forEach((accordion) => {
      const items = accordion.querySelectorAll('.accordion-item');

      items.forEach((item) => {
        const button = item.querySelector('button');
        const panel = item.querySelector<HTMLElement>('.accordion-panel');
        if (!button || !panel) return;

        button.addEventListener('click', () => {
          const isExpanded = item.getAttribute('data-expanded') === 'true';
          const itemIndex = Array.from(items).indexOf(item);

          // Collapse all items
          items.forEach((otherItem) => {
            otherItem.setAttribute('data-expanded', 'false');
            otherItem.classList.remove('border-yellow-tennis');
            otherItem.classList.add('border-transparent');
            const otherButton = otherItem.querySelector('button');
            const otherPanel = otherItem.querySelector<HTMLElement>('.accordion-panel');
            if (otherButton) otherButton.setAttribute('aria-expanded', 'false');
            if (otherPanel) {
              otherPanel.classList.remove('max-h-[300px]', 'opacity-100');
              otherPanel.classList.add('max-h-0', 'opacity-0');
            }
          });

          // Hide all illustrations
          const illustrations = accordion.closest('section')?.querySelectorAll('.accordion-illustration');
          illustrations?.forEach((img) => {
            img.classList.remove('opacity-100');
            img.classList.add('opacity-0');
          });

          // Expand clicked item (if it was collapsed)
          if (!isExpanded) {
            item.setAttribute('data-expanded', 'true');
            item.classList.add('border-yellow-tennis');
            item.classList.remove('border-transparent');
            button.setAttribute('aria-expanded', 'true');
            panel.classList.add('max-h-[300px]', 'opacity-100');
            panel.classList.remove('max-h-0', 'opacity-0');

            // Show matching illustration
            const targetIllustration = accordion.closest('section')?.querySelector(`[data-illustration-index="${itemIndex}"]`);
            if (targetIllustration) {
              targetIllustration.classList.remove('opacity-0');
              targetIllustration.classList.add('opacity-100');
            }
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initAccordions);
  initAccordions();
</script>
