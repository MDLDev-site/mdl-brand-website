---
import type { HeroSection, LogoBannerSection } from '../../types/content';

interface Props {
  section: HeroSection;
  logoBanner?: LogoBannerSection;
}

const { section, logoBanner } = Astro.props;
---

{/* Hero with image + radial gradient that fades to feature-section grey at
   the edges/bottom. Logo banner is rendered INSIDE the hero (per Figma
   node 241:26563) so the gradient flows over the logos and the diagonal
   between hero and the next feature section can be removed. */}
<section
  class="relative overflow-hidden bg-grey"
  aria-label="Hero"
>
  {/* Background image */}
  {section.backgroundImage && (
    <img
      src={section.backgroundImage}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
  )}

  {/* Dark navy gradients — keep edges of hero text area dark for contrast */}
  <div class="absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, var(--color-navy-umpire) 0%, transparent 35%, transparent 55%, transparent 100%);"
    ></div>
    <div
      class="absolute inset-0"
      style="background: linear-gradient(90deg, var(--color-navy-umpire) 0%, transparent 25%, transparent 75%, var(--color-navy-umpire) 100%);"
    ></div>
  </div>

  {/* Radial gradient — transparent in centre, fading to feature-section
       grey at the edges/bottom. Replaces the diagonal previously between
       hero and feature sections. */}
  <div
    class="absolute inset-0"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 70% 80% at 50% 30%, transparent 0%, transparent 30%, var(--color-grey) 100%);"
  ></div>

  {/* Hero text content */}
  <div class="relative z-10 mx-auto flex max-w-360 flex-col items-center gap-12.5 px-[24px] pt-35 pb-25 text-center md:px-30 md:pt-45 md:pb-35">
    <h1 class="text-h1 text-white">
      {section.heading.map((line) => (
        <span class="block">{line}</span>
      ))}
    </h1>

    {section.subtitle && (
      <p class="font-subheading text-[18px] font-medium leading-[1.3] text-white/90 md:text-[22px]">
        {section.subtitle}
      </p>
    )}

    <p class="max-w-150 text-body-lg text-white/80">
      {section.subheading}
    </p>

    <div class="flex w-full max-w-85 flex-col items-center gap-[16px] sm:w-auto sm:max-w-none sm:flex-row sm:gap-[24px]">
      <a
        href={section.cta.primary.link}
        class="inline-flex w-full items-center justify-center rounded-sm bg-blue-matchday px-[32px] py-[16px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[2px] text-white transition-colors hover:bg-blue-matchday/90 sm:w-auto"
      >
        {section.cta.primary.text}
      </a>

      <a
        href={section.cta.secondary.link}
        class="group inline-flex items-center gap-[8px] py-[8px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-white transition-colors hover:text-yellow-tennis"
      >
        {section.cta.secondary.text}
        <svg
          class="h-[16px] w-[16px] transition-transform group-hover:translate-x-[4px]"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>

  {/* Logo banner — sits inside the hero, on top of the radial gradient
       grey area. No bg of its own (the gradient provides it). */}
  {logoBanner && (
    <div class="relative z-10 mx-auto flex max-w-360 flex-col items-center gap-[32px] px-[24px] pt-[16px] pb-[64px] md:px-30">
      <h4 class="text-h4 text-center text-charcoal-pitch">
        {logoBanner.heading}
      </h4>

      <ul class="flex flex-wrap items-center justify-center gap-x-[16px] gap-y-[24px] md:gap-10" role="list">
        {logoBanner.logos.map((logo) => (
          <li class="flex items-center justify-center">
            {logo.src ? (
              <img
                src={logo.src}
                alt={logo.alt}
                class="h-10 w-auto max-w-20 object-contain md:h-15 md:max-w-30"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div
                class="flex h-10 w-10 items-center justify-center rounded-sm bg-charcoal-pitch/10 md:h-15 md:w-15"
                role="img"
                aria-label={logo.alt}
              >
                <span class="text-note text-charcoal-pitch/40">Logo</span>
              </div>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}
</section>
