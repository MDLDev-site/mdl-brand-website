---
import type { PricingComparison, PricingProduct } from '../../types/content';

interface Props {
  comparisons: PricingComparison[];
  products: PricingProduct[];
}

const { comparisons, products } = Astro.props;

function findProduct(productId: string) {
  return products.find((p) => p.id === productId);
}
---

<section class="bg-white py-[48px] md:py-25" aria-label="Plan comparison">
  <div class="mx-auto max-w-360 px-[24px] md:px-30">
    {comparisons.map((comparison, idx) => {
      const product = findProduct(comparison.productId);
      if (!product) return null;
      return (
        <div
          class={`pricing-comparison ${idx === 0 ? '' : 'hidden'}`}
          data-comparison={comparison.productId}
        >
          {/* Tier label strip — STICKY at top of viewport once the
              user scrolls into the comparison rows (designer ask,
              May 19). Keeps the tier name + price visible against the
              feature columns. `top-[80px]` clears the fixed site
              header so the strip is fully readable when stuck. */}
          <div class="sticky top-[80px] z-30 -mx-[24px] mb-[24px] border-b border-charcoal-pitch/10 bg-white/95 px-[24px] py-[12px] shadow-[0_2px_10px_rgba(0,0,0,0.06)] backdrop-blur-md md:-mx-30 md:px-30">
            <div class="mx-auto max-w-360">
              <div class="grid grid-cols-[minmax(0,2fr)_repeat(4,minmax(0,1fr))] gap-[8px] md:gap-[16px]">
                <div></div>
                {product.tiers.map((tier) => (
                  <div class="flex flex-col items-center gap-[4px] text-center">
                    <span class="font-subheading text-[10px] font-semibold uppercase tracking-[0.2px] text-charcoal-pitch md:text-[12px]">
                      {tier.name}
                    </span>
                    <span
                      class="pricing-price font-heading text-[16px] font-medium leading-none text-charcoal-pitch md:text-[20px]"
                      data-monthly={tier.monthlyPrice}
                      data-annual={tier.annualPrice}
                    >
                      {tier.monthlyPrice}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Groups — collapsible accordions per DEV-2276. First group
              opens by default so the table reads as before above-the-fold. */}
          {comparison.groups.map((group, gIdx) => (
            <details
              class="pricing-comparison-group group mb-[16px] border-b border-charcoal-pitch/10"
              open={gIdx === 0}
            >
              <summary class="flex cursor-pointer list-none items-center justify-between gap-[16px] py-[16px]">
                <h3 class="font-subheading text-[14px] font-semibold uppercase tracking-[0.28px] text-charcoal-pitch md:text-[16px]">
                  {group.heading}
                </h3>
                <svg
                  class="h-5 w-5 shrink-0 text-charcoal-pitch transition-transform group-open:rotate-45"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </summary>
              <div class="flex flex-col pb-[16px]">
                {group.rows.map((row) => (
                  <div class="grid grid-cols-[minmax(0,2fr)_repeat(4,minmax(0,1fr))] items-center gap-[8px] border-b border-charcoal-pitch/5 py-[10px] md:gap-[16px]">
                    <span class="font-body text-[12px] font-normal leading-tight text-text-primary md:text-[14px]">
                      {row.label}
                    </span>
                    {row.values.map((cell) => (
                      <div class="flex justify-center">
                        {typeof cell.value === 'boolean' ? (
                          cell.value ? (
                            <span class="flex h-[24px] w-[24px] items-center justify-center rounded-full bg-yellow-tennis">
                              <svg class="h-3 w-3 text-charcoal-pitch" viewBox="0 0 16 16" fill="none">
                                <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                              </svg>
                            </span>
                          ) : (
                            <span class="font-body text-[14px] text-charcoal-pitch/30">—</span>
                          )
                        ) : (
                          <span class="text-center font-body text-[12px] font-medium text-charcoal-pitch md:text-[14px]">
                            {cell.value}
                          </span>
                        )}
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </details>
          ))}
        </div>
      );
    })}
  </div>
</section>

<script>
  function initPricingComparison() {
    // Sync comparison visibility with product tab selection
    const tabs = document.querySelectorAll<HTMLButtonElement>('.pricing-product-tab');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const productId = tab.dataset.productTab;
        if (!productId) return;
        document
          .querySelectorAll<HTMLElement>('[data-comparison]')
          .forEach((c) => c.classList.toggle('hidden', c.dataset.comparison !== productId));
      });
    });
  }

  document.addEventListener('astro:page-load', initPricingComparison);
  initPricingComparison();
</script>
