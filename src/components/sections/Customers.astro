---
import type { CustomerSection } from '../../types/content';

interface Props {
  section: CustomerSection;
}

const { section } = Astro.props;
---

<section class="bg-grey py-20 md:py-30" aria-label={section.heading}>
  <div class="mx-auto max-w-360">
    {/* Header row */}
    <div class="flex items-end justify-between px-[24px] pb-[48px] md:px-30">
      <h2 class="font-heading text-[50px] font-medium uppercase leading-[0.9] tracking-[-1px] text-charcoal-pitch md:text-[80px] md:tracking-[1px]">
        {section.heading}
      </h2>

      <div class="hidden items-center gap-[12px] md:flex" role="group" aria-label="Case study navigation">
        <button
          class="customers-prev flex h-10 w-10 items-center justify-center rounded-full border border-charcoal-pitch/20 transition-colors hover:bg-charcoal-pitch/5"
          aria-label="Previous case study"
          type="button"
        >
          <svg class="h-[16px] w-[16px] text-charcoal-pitch" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button
          class="customers-next flex h-10 w-10 items-center justify-center rounded-full bg-yellow-tennis transition-colors hover:bg-yellow-tennis/80"
          aria-label="Next case study"
          type="button"
        >
          <svg class="h-[16px] w-[16px] text-charcoal-pitch" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>

    {/* Cards container with decorative circles */}
    <div class="relative">
      {/* Decorative orange circle outlines */}
      <div class="pointer-events-none absolute inset-0 hidden overflow-hidden md:block" aria-hidden="true">
        <svg class="absolute -top-10 left-10 h-20 w-20" viewBox="0 0 80 80" fill="none">
          <circle cx="40" cy="40" r="38" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.4" />
        </svg>
        <svg class="absolute -top-5 left-50 h-15 w-15" viewBox="0 0 60 60" fill="none">
          <circle cx="30" cy="30" r="28" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.3" />
        </svg>
        <svg class="absolute top-2.5 left-85 h-12.5 w-12.5" viewBox="0 0 50 50" fill="none">
          <circle cx="25" cy="25" r="23" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.3" />
        </svg>
        <svg class="absolute -top-7.5 right-50 h-17.5 w-17.5" viewBox="0 0 70 70" fill="none">
          <circle cx="35" cy="35" r="33" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.3" />
        </svg>
        <svg class="absolute -top-2.5 right-15 h-15 w-15" viewBox="0 0 60 60" fill="none">
          <circle cx="30" cy="30" r="28" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.4" />
        </svg>
        <svg class="absolute top-5 -right-2.5 h-12.5 w-12.5" viewBox="0 0 50 50" fill="none">
          <circle cx="25" cy="25" r="23" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.3" />
        </svg>
        <svg class="absolute -top-12.5 left-125 h-22.5 w-22.5" viewBox="0 0 90 90" fill="none">
          <circle cx="45" cy="45" r="43" stroke="var(--color-orange-basketball)" stroke-width="2" opacity="0.25" />
        </svg>
      </div>

      {/* Case study cards track */}
      <div
        class="customers-track flex gap-[24px] overflow-x-auto px-[24px] pb-[8px] scrollbar-hide md:px-30"
        role="list"
        style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;"
      >
        {section.caseStudies.map((study) => (
          <article
            class="relative flex h-100 w-[85vw] shrink-0 flex-col overflow-hidden rounded-[16px] md:h-125 md:w-175"
            role="listitem"
            style="scroll-snap-align: start;"
          >
            {/* Background image */}
            {study.backgroundImage && (
              <img
                src={study.backgroundImage}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
                loading="lazy"
                decoding="async"
                aria-hidden="true"
              />
            )}

            {/* Gradient overlay — brand color from bottom */}
            <div
              class="absolute inset-0"
              style={`background: linear-gradient(0deg, ${study.gradientColor || 'rgba(22,29,37,0.9)'} 0%, ${study.gradientColor}99 40%, transparent 80%);`}
              aria-hidden="true"
            ></div>

            {/* Content */}
            <div class="relative z-10 flex h-full flex-col justify-between p-[24px] md:p-10">
              {/* Brand logo — top left */}
              {study.brandLogo && (
                <img
                  src={study.brandLogo}
                  alt={study.brandName}
                  class="h-15 w-15 object-contain md:h-20 md:w-20"
                  loading="lazy"
                  decoding="async"
                />
              )}

              {/* Quote + CTA — bottom */}
              <div class="flex flex-col gap-5">
                <blockquote class="font-heading text-[24px] font-medium uppercase leading-[0.9] tracking-[-0.5px] text-white md:text-[36px]">
                  {study.quote}
                </blockquote>

                <a
                  href={study.cta.link}
                  class="inline-flex w-fit items-center rounded-sm bg-white px-[24px] py-[12px] font-body text-[14px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-charcoal-pitch transition-colors hover:bg-white/90 md:px-[32px] md:py-3.5 md:text-[16px]"
                >
                  {study.cta.text}
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    {/* Pagination dots */}
    <div class="flex items-center justify-center gap-[8px] pt-[32px]" aria-hidden="true">
      {section.caseStudies.map((_, i) => (
        <div
          class:list={[
            'customers-dot h-[4px] rounded-full transition-all',
            i === 0 ? 'w-[32px] bg-charcoal-pitch' : 'w-[24px] bg-charcoal-pitch/20',
          ]}
          data-dot-index={i}
        ></div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initCustomerCarousels() {
    const tracks = document.querySelectorAll<HTMLElement>('.customers-track');

    tracks.forEach((track) => {
      const section = track.closest('section');
      if (!section) return;

      const prevBtn = section.querySelector<HTMLButtonElement>('.customers-prev');
      const nextBtn = section.querySelector<HTMLButtonElement>('.customers-next');
      const cards = track.querySelectorAll('article');
      const dots = section.querySelectorAll('.customers-dot');

      function updateDots() {
        const scrollLeft = track.scrollLeft;
        const cardWidth = (cards[0] as HTMLElement)?.offsetWidth || 700;
        const activeIndex = Math.round(scrollLeft / (cardWidth + 24));
        dots.forEach((dot, i) => {
          if (i === activeIndex) {
            dot.classList.add('w-[32px]', 'bg-charcoal-pitch');
            dot.classList.remove('w-[24px]', 'bg-charcoal-pitch/20');
          } else {
            dot.classList.remove('w-[32px]', 'bg-charcoal-pitch');
            dot.classList.add('w-[24px]', 'bg-charcoal-pitch/20');
          }
        });
      }

      track.addEventListener('scroll', updateDots);

      const scrollAmount = ((cards[0] as HTMLElement)?.offsetWidth || 700) + 24;

      prevBtn?.addEventListener('click', () => {
        track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn?.addEventListener('click', () => {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    });
  }

  document.addEventListener('astro:page-load', initCustomerCarousels);
  initCustomerCarousels();
</script>
