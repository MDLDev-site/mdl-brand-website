---
import type { CustomerSection } from '../../types/content';

interface Props {
  section: CustomerSection;
}

const { section } = Astro.props;
---

<section class="bg-grey py-20 md:py-30" aria-label={section.heading}>
  <div class="mx-auto max-w-360">
    {/* Header row — padding aligns with the carousel track (DEV-2300) */}
    <div class="flex items-end justify-between px-[32px] pb-[48px] md:px-30">
      <h2 class="text-h1 text-charcoal-pitch">
        {section.heading}
      </h2>

      <div class="hidden items-center gap-[12px] md:flex" role="group" aria-label="Case study navigation">
        <button
          class="customers-prev flex h-10 w-10 items-center justify-center rounded-full border border-charcoal-pitch/20 transition-colors hover:bg-charcoal-pitch/5"
          aria-label="Previous case study"
          type="button"
        >
          <svg class="h-[16px] w-[16px] text-charcoal-pitch" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button
          class="customers-next flex h-10 w-10 items-center justify-center rounded-full bg-yellow-tennis transition-colors hover:bg-yellow-tennis/80"
          aria-label="Next case study"
          type="button"
        >
          <svg class="h-[16px] w-[16px] text-charcoal-pitch" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>

    <div class="relative">
      {/* Case study cards track — DEV-2300 sets card dims:
          mobile width = calc(100vw - 64px), desktop width = calc(100vw - 240px),
          height fixed 500px on both.
          DEV-2337 — extra vertical padding inside the track so the card
          dropshadow isn't clipped by the auto-scroll overflow box.
          Larger horizontal gap so the right-side shadow has room to
          breathe between adjacent cards. */}
      <div
        class="customers-track flex touch-pan-x gap-[32px] overflow-x-auto px-[32px] py-[16px] scrollbar-hide md:px-30"
        role="list"
        style="scroll-snap-type: x mandatory; scroll-padding-left: 32px; -webkit-overflow-scrolling: touch;"
      >
        {section.caseStudies.map((study) => {
          // Card: bg image + horizontal gradient (brand colour left -> transparent
          // right, per Figma 202:18690) + logo + quote + button. Always rendered
          // dynamically from CMS (preComposed retained as a fallback only).
          const cardClass = 'customer-card group relative flex shrink-0 flex-col overflow-hidden rounded-[16px] shadow-card-lg cursor-pointer transition-transform hover:scale-[1.01]';
          const cardStyle = `scroll-snap-align: start;${study.backgroundColor ? ` background-color: ${study.backgroundColor};` : ''}`;

          const backgroundImage = study.backgroundImage ? (
            <img
              src={study.backgroundImage}
              alt={study.preComposed ? `${study.brandName}: ${study.quote}` : ''}
              class="absolute inset-0 h-full w-full object-cover object-center"
              loading="lazy"
              decoding="async"
              aria-hidden={study.preComposed ? undefined : 'true'}
            />
          ) : null;

          // preComposed = legacy single-image cards (kept for back-compat).
          // Default = dynamic overlay with bg + gradient + logo + heading + button.
          if (study.preComposed) {
            return (
              <a
                href={study.cta.link}
                class={cardClass}
                style={cardStyle}
                aria-label={`${study.brandName} case study — ${study.quote}`}
              >
                {backgroundImage}
              </a>
            );
          }

          const gradientColor = study.gradientColor || '#152644';
          return (
            <a
              href={study.cta.link}
              class={cardClass}
              style={cardStyle}
              aria-label={`${study.brandName} case study — ${study.quote}`}
            >
              {backgroundImage}
              {/* Linear gradient overlay: brand colour on the left, fading to
                  transparent on the right. Matches Figma 202:18687/8/9. */}
              <div
                class="absolute inset-0"
                style={`background: linear-gradient(90deg, ${gradientColor} 0%, transparent 100%);`}
                aria-hidden="true"
              ></div>
              <div class="relative z-10 flex h-full flex-col justify-between p-[32px] md:p-[40px]">
                {study.brandLogo && (
                  <img
                    src={study.brandLogo}
                    alt={study.brandName}
                    class="h-15 w-15 object-contain md:h-20 md:w-20"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                {/* Button hidden until case studies launch (DEV-2230/2301) —
                  CTA data retained on the wrapping <a> so the entire card
                  remains clickable / linkable from the CMS. */}
                <div class="flex flex-col gap-[24px]">
                  <blockquote class="text-h3 max-w-110 text-white">
                    {study.quote}
                  </blockquote>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    {/* Pagination dots — 24px below the cards (DEV-2299) */}
    <div class="flex items-center justify-center gap-[8px] pt-[24px]" aria-hidden="true">
      {section.caseStudies.map((_, i) => (
        <div
          class:list={[
            'customers-dot h-[4px] rounded-full transition-all',
            i === 0 ? 'w-[32px] bg-charcoal-pitch' : 'w-[24px] bg-charcoal-pitch/20',
          ]}
          data-dot-index={i}
        ></div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Card dims per DEV-2300 — full viewport width minus the side padding
     so the card sits flush within the section margins. Fixed 500px tall
     across breakpoints. */
  .customer-card {
    width: calc(100vw - 64px);
    height: 500px;
  }
  @media (min-width: 768px) {
    .customer-card {
      width: calc(100vw - 240px);
      max-width: 1200px;
    }
  }
</style>

<script>
  function initCustomerCarousels() {
    const tracks = document.querySelectorAll<HTMLElement>('.customers-track');

    tracks.forEach((track) => {
      const section = track.closest('section');
      if (!section) return;

      const prevBtn = section.querySelector<HTMLButtonElement>('.customers-prev');
      const nextBtn = section.querySelector<HTMLButtonElement>('.customers-next');
      const cards = track.querySelectorAll<HTMLElement>('.customer-card');
      const dots = section.querySelectorAll('.customers-dot');

      function updateDots() {
        const scrollLeft = track.scrollLeft;
        const cardWidth = (cards[0] as HTMLElement)?.offsetWidth || 700;
        const activeIndex = Math.round(scrollLeft / (cardWidth + 32));
        dots.forEach((dot, i) => {
          if (i === activeIndex) {
            dot.classList.add('w-[32px]', 'bg-charcoal-pitch');
            dot.classList.remove('w-[24px]', 'bg-charcoal-pitch/20');
          } else {
            dot.classList.remove('w-[32px]', 'bg-charcoal-pitch');
            dot.classList.add('w-[24px]', 'bg-charcoal-pitch/20');
          }
        });
      }

      track.addEventListener('scroll', updateDots);

      // Snap initial scroll to 0 so the first card frame aligns with the
      // section heading (both share horizontal padding).
      requestAnimationFrame(() => {
        track.scrollLeft = 0;
      });

      // Keep scroll-padding in sync with the responsive section padding so
      // snapping respects the heading alignment (DEV-2300 widened the cards
      // so the track padding bumped to 32px mobile / 120px desktop).
      const updateScrollPadding = () => {
        const isDesktop = window.matchMedia('(min-width: 768px)').matches;
        track.style.scrollPaddingLeft = isDesktop ? '120px' : '32px';
      };
      updateScrollPadding();
      window.addEventListener('resize', updateScrollPadding);

      // Scroll step matches card width + gap (kept in sync with the
      // 32px gap set on .customers-track per DEV-2337).
      const scrollAmount = ((cards[0] as HTMLElement)?.offsetWidth || 700) + 32;

      prevBtn?.addEventListener('click', () => {
        track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn?.addEventListener('click', () => {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    });
  }

  document.addEventListener('astro:page-load', initCustomerCarousels);
  initCustomerCarousels();
</script>
