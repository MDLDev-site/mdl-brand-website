---
import type { DiagonalsSection } from '../../types/content';

interface Props {
  section: DiagonalsSection;
}

const { section } = Astro.props;
const variant = section.variant;
---

{variant === 'grey-to-white' && (
  <div class="relative h-[24px] md:h-20 bg-grey">
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1200 80" preserveAspectRatio="none" fill="none">
      <polygon points="0,0 1200,80 1200,80 0,80" fill="var(--color-surface-primary)" />
    </svg>
  </div>
)}

{variant === 'white-to-grey' && (
  <div class="relative h-[24px] md:h-20 bg-white">
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1200 80" preserveAspectRatio="none" fill="none">
      <polygon points="0,0 1200,80 1200,80 0,80" fill="var(--color-grey)" />
    </svg>
  </div>
)}

{variant === 'white-to-navy' && (
  <div class="relative h-[40px] md:h-20 bg-white overflow-hidden">
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1200 80" preserveAspectRatio="none" fill="none">
      <polygon points="0,80 1200,0 1200,80" fill="var(--color-navy-umpire)" />
    </svg>
  </div>
)}

{variant === 'color-strips' && (
  <div class="relative h-[40px] md:h-26.5 bg-grey overflow-hidden">
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1200 106" preserveAspectRatio="none" fill="none">
      {/* Navy triangle creates the grey -> navy diagonal transition
          between the customers (grey) and accordion (navy) sections.
          Diagonal runs from bottom-left (0,106) to top-right (1200,0). */}
      <polygon points="0,106 1200,0 1200,106" fill="var(--color-navy-umpire)" />
      {/* DEV-2305 — colour strips matching Figma 25:6142.
          Two parallelograms running PARALLEL to the diagonal on the
          grey side, both terminating around 50% width with a clean
          diagonal cut (no spike points). Yellow is the dominant band
          sitting right against the diagonal; blue sits just above it. */}
      <polygon points="0,76 600,23 600,48 0,101" fill="var(--color-yellow-tennis)" />
      <polygon points="0,56 470,14 470,26 0,68" fill="var(--color-blue-matchday)" />
    </svg>
  </div>
)}
