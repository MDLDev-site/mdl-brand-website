---
import type { CarouselSection } from '../../types/content';

interface Props {
  section: CarouselSection;
}

const { section } = Astro.props;
---

<section class="bg-grey py-20 md:py-30" aria-label={section.heading}>
  <div class="mx-auto max-w-360">
    {/* Header row */}
    <div class="flex items-end justify-between px-[24px] pb-[48px] md:px-30">
      <h2 class="text-h1 max-w-150 text-charcoal-pitch">
        {section.heading}
      </h2>

      <div class="hidden items-center gap-[12px] md:flex" role="group" aria-label="Carousel navigation">
        <button
          class="carousel-prev flex h-14 w-14 items-center justify-center rounded-full border border-light-football transition-colors hover:bg-light-football"
          aria-label="Previous slide"
          type="button"
        >
          <svg class="h-5 w-5 text-charcoal-pitch" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button
          class="carousel-next flex h-14 w-14 items-center justify-center rounded-full bg-yellow-tennis transition-colors hover:bg-yellow-tennis/80"
          aria-label="Next slide"
          type="button"
        >
          <svg class="h-5 w-5 text-charcoal-pitch" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>

    {/* Cards track — DEV-2338: touch-action pan-x restricts the
        scroll-snap container to horizontal panning so vertical drags
        bubble back to the page. Without it mobile users get stuck on
        the carousel until they tap outside. */}
    <div
      class="carousel-track flex touch-pan-x gap-[24px] overflow-x-auto overflow-y-visible px-[24px] pt-[8px] pb-[48px] scrollbar-hide md:px-30 md:pb-[64px]"
      role="list"
      style="scroll-snap-type: x mandatory; scroll-padding-left: 24px; -webkit-overflow-scrolling: touch;"
      data-md-scroll-padding="120"
    >
      {section.cards.map((card) => (
        <article
          class="flex w-75 shrink-0 flex-col rounded-md border-t-8 border-blue-matchday bg-white shadow-card md:w-95"
          role="listitem"
          style="scroll-snap-align: start;"
        >
          <div class="flex flex-1 flex-col gap-[16px] px-[32px] pt-[48px] pb-9 md:px-[48px] md:pt-[64px] md:pb-[48px]">
            <h3 class="text-h4 text-charcoal-pitch">
              {card.title}
            </h3>
            <p class="text-body-lg text-text-primary">
              {card.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initCarousels() {
    const tracks = document.querySelectorAll<HTMLElement>('.carousel-track');

    tracks.forEach((track) => {
      const section = track.closest('section');
      if (!section) return;

      // On init, snap scroll to 0 so the first card frame aligns with the
      // section heading (both share the same horizontal padding). Without
      // this, scroll-snap-type:mandatory pulls the first card's left edge
      // into the snap-port start, which sits inside the padding.
      const setInitialScroll = () => {
        track.scrollLeft = 0;
      };
      // Run after layout settles
      requestAnimationFrame(setInitialScroll);

      const prevBtn = section.querySelector<HTMLButtonElement>('.carousel-prev');
      const nextBtn = section.querySelector<HTMLButtonElement>('.carousel-next');
      const scrollAmount = 404; // card width + gap

      prevBtn?.addEventListener('click', () => {
        track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn?.addEventListener('click', () => {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });

      // Also keep scroll-padding in sync with viewport (desktop matches
      // section padding so snapping respects the heading alignment).
      const updateScrollPadding = () => {
        const isDesktop = window.matchMedia('(min-width: 768px)').matches;
        track.style.scrollPaddingLeft = isDesktop ? '120px' : '24px';
      };
      updateScrollPadding();
      window.addEventListener('resize', updateScrollPadding);
    });
  }

  document.addEventListener('astro:page-load', initCarousels);
  initCarousels();
</script>
