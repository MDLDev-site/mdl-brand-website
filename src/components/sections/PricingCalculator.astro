---
import type { PricingCalculator, PricingProduct } from '../../types/content';

interface Props {
  calculator: PricingCalculator;
  products: PricingProduct[];
}

const { calculator, products } = Astro.props;
---

<div
  class="pricing-calc-modal fixed inset-0 z-[60] hidden items-start justify-center overflow-y-auto bg-charcoal-pitch/80 p-[16px] backdrop-blur-sm md:items-center md:p-[40px]"
  data-calc-modal
  data-active-product="on-demand"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label={calculator.heading}
>
  <div class="relative my-[32px] w-full max-w-220 rounded-[16px] bg-charcoal-pitch p-[24px] ring-1 ring-white/10 md:p-[40px]">
    {/* Close button */}
    <button
      type="button"
      class="absolute -top-[16px] right-[16px] flex h-[40px] w-[40px] items-center justify-center rounded-full bg-white text-charcoal-pitch shadow-md hover:bg-grey md:-top-[20px] md:-right-[20px] md:h-[48px] md:w-[48px]"
      data-calc-close
      aria-label="Close calculator"
    >
      <svg class="h-[16px] w-[16px]" viewBox="0 0 16 16" fill="none">
        <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>

    {/* Heading */}
    <div class="flex flex-col gap-[8px]">
      <h2 class="font-body text-[16px] font-semibold text-white md:text-[18px]">
        {calculator.heading}
      </h2>
      <p class="font-body text-[14px] font-normal leading-[1.4] text-white/70">
        {calculator.description}
      </p>
    </div>

    {/* Product type tabs (modal) */}
    <div class="mt-[24px] grid grid-cols-1 gap-[12px] md:grid-cols-2 md:gap-[16px]">
      {products.map((product, i) => (
        <button
          type="button"
          class={`pricing-calc-tab group flex flex-col items-center gap-[8px] rounded-[12px] px-[16px] py-[24px] text-center transition-colors ${i === 0 ? 'is-active' : ''}`}
          data-calc-tab={product.id}
        >
          <span class="calc-tab-label font-heading text-[24px] font-medium uppercase leading-none tracking-[-0.5px] md:text-[32px]">
            {product.tabLabel}
          </span>
          <span class="calc-tab-desc max-w-90 font-body text-[12px] font-normal leading-[1.4] md:text-[14px]">
            {product.description}
          </span>
        </button>
      ))}
    </div>

    {/* Per-product slider sets — only the active product's sliders are
        visible. DEV-2283/2285. */}
    {products.map((product, i) => {
      const productSet = calculator.productSliders[product.id];
      if (!productSet) return null;
      return (
        <div
          class={`calc-product-sliders mt-[24px] ${i === 0 ? '' : 'hidden'}`}
          data-product-sliders={product.id}
        >
          <div class="grid grid-cols-1 gap-[24px] md:grid-cols-3 md:gap-[32px]">
            {productSet.sliders.map((slider) => (
              <div class="flex flex-col gap-[12px]">
                <div class="flex items-center gap-[6px]">
                  <label
                    for={`calc-${product.id}-${slider.id}`}
                    class="font-body text-[13px] font-medium text-white"
                  >
                    {slider.label}
                  </label>
                  <button
                    type="button"
                    class="calc-tooltip-trigger relative flex h-[16px] w-[16px] items-center justify-center text-white/60 hover:text-white"
                    data-tooltip={slider.tooltip}
                    aria-label="More info"
                  >
                    <svg class="h-[14px] w-[14px]" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" />
                      <path d="M8 7v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                      <circle cx="8" cy="5" r="0.6" fill="currentColor" />
                    </svg>
                  </button>
                </div>
                <input
                  id={`calc-${product.id}-${slider.id}`}
                  type="range"
                  class="calc-slider"
                  min={slider.min}
                  max={slider.max}
                  step={slider.step}
                  value={slider.default}
                  data-slider={slider.id}
                  data-slider-product={product.id}
                />
                <div class="flex justify-between font-body text-[10px] font-medium text-white/60">
                  {slider.ticks.map((t) => (<span>{t}</span>))}
                </div>
              </div>
            ))}
          </div>

          {/* Refine On-Demand Consumption — collapsible sub-group only
              shown for the Live & On-Demand product. DEV-2285. */}
          {productSet.refineOnDemand && (
            <details class="calc-refine-od group mt-[24px] rounded-[12px] border border-white/10 bg-white/5 p-[16px] md:p-[20px]">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-[12px]">
                <span class="font-body text-[14px] font-semibold text-white">
                  {productSet.refineOnDemand.label}
                </span>
                <svg
                  class="h-5 w-5 shrink-0 text-white/70 transition-transform group-open:rotate-45"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </summary>
              {productSet.refineOnDemand.helper && (
                <p class="mt-[8px] font-body text-[12px] leading-[1.5] text-white/60">
                  {productSet.refineOnDemand.helper}
                </p>
              )}
              <div class="mt-[16px] grid grid-cols-1 gap-[20px] md:grid-cols-2 md:gap-[24px]">
                {productSet.refineOnDemand.sliders.map((slider) => (
                  <div class="flex flex-col gap-[12px]">
                    <div class="flex items-center gap-[6px]">
                      <label
                        for={`calc-${product.id}-refine-${slider.id}`}
                        class="font-body text-[13px] font-medium text-white"
                      >
                        {slider.label}
                      </label>
                      <button
                        type="button"
                        class="calc-tooltip-trigger relative flex h-[16px] w-[16px] items-center justify-center text-white/60 hover:text-white"
                        data-tooltip={slider.tooltip}
                        aria-label="More info"
                      >
                        <svg class="h-[14px] w-[14px]" viewBox="0 0 16 16" fill="none">
                          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" />
                          <path d="M8 7v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                          <circle cx="8" cy="5" r="0.6" fill="currentColor" />
                        </svg>
                      </button>
                    </div>
                    <input
                      id={`calc-${product.id}-refine-${slider.id}`}
                      type="range"
                      class="calc-slider"
                      min={slider.min}
                      max={slider.max}
                      step={slider.step}
                      value={slider.default}
                      data-slider={slider.id}
                      data-slider-product={product.id}
                      data-slider-refine="true"
                    />
                    <div class="flex justify-between font-body text-[10px] font-medium text-white/60">
                      {slider.ticks.map((t) => (<span>{t}</span>))}
                    </div>
                  </div>
                ))}
              </div>
            </details>
          )}
        </div>
      );
    })}

    {/* Output panel — shows helper text until all sliders interacted with
        (DEV-2284); recommendation tier appears once interaction is
        complete. Layout updated per DEV-2334 (Figma 196-15241) — the
        recommended plan + "View plan" link sit alongside the figures.
        For On-Demand only Bandwidth is shown (no hours) per DEV-2330. */}
    <div class="mt-[24px] flex flex-col gap-[16px] rounded-[12px] bg-white px-[24px] py-[20px] md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-[4px]">
        <p class="font-body text-[14px] font-semibold text-charcoal-pitch">
          {calculator.outputs.consumptionLabel}
        </p>
        {/* Empty state — visible until all sliders touched */}
        <p
          class="calc-empty-state font-body text-[12px] font-medium leading-[1.4] text-charcoal-pitch/60"
          data-calc-empty
        >
          {calculator.outputs.consumptionEmpty ?? 'Drag all sliders to view your estimated consumption'}
        </p>
        {/* Recommendation — hidden until all sliders touched. View Plan
            link closes the calculator and scrolls the pricing page to
            the recommended tier card (DEV-2334). */}
        <div class="calc-recommendation hidden" data-calc-recommendation>
          <p class="font-body text-[14px] text-charcoal-pitch/70">
            {calculator.outputs.recommendationPrefix}
            <span class="calc-plan-name ml-[4px] font-semibold" data-calc-plan>—</span>
          </p>
          <button
            type="button"
            class="calc-view-plan mt-[4px] inline-flex items-center gap-[4px] font-body text-[13px] font-medium hover:underline"
            data-calc-view-plan
          >
            View plan
            <svg class="h-[12px] w-[12px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>

      <div class="calc-figures flex gap-[24px] opacity-40 transition-opacity md:gap-[40px]" data-calc-figures>
        {/* Hours figure — only relevant for Live product (DEV-2330) */}
        <div class="calc-figure-hours flex flex-col gap-[4px]" data-calc-figure="hours">
          <div class="flex items-center gap-[6px]">
            <span class="font-body text-[12px] font-medium text-charcoal-pitch/70">
              {calculator.outputs.hoursLabel}
            </span>
            <button
              type="button"
              class="calc-tooltip-trigger flex h-[14px] w-[14px] items-center justify-center text-charcoal-pitch/40 hover:text-charcoal-pitch"
              data-tooltip={calculator.outputs.hoursTooltip}
              aria-label="More info"
            >
              <svg class="h-[12px] w-[12px]" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" />
                <path d="M8 7v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                <circle cx="8" cy="5" r="0.6" fill="currentColor" />
              </svg>
            </button>
          </div>
          <p class="font-heading text-[24px] font-medium leading-none text-charcoal-pitch">
            <span data-calc-hours>—</span> <span class="text-[14px]">hrs</span>
          </p>
        </div>
        <div class="flex flex-col gap-[4px]">
          <div class="flex items-center gap-[6px]">
            <span class="font-body text-[12px] font-medium text-charcoal-pitch/70">
              {calculator.outputs.bandwidthLabel}
            </span>
            <button
              type="button"
              class="calc-tooltip-trigger flex h-[14px] w-[14px] items-center justify-center text-charcoal-pitch/40 hover:text-charcoal-pitch"
              data-tooltip={calculator.outputs.bandwidthTooltip}
              aria-label="More info"
            >
              <svg class="h-[12px] w-[12px]" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" />
                <path d="M8 7v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                <circle cx="8" cy="5" r="0.6" fill="currentColor" />
              </svg>
            </button>
          </div>
          <p class="font-heading text-[24px] font-medium leading-none text-charcoal-pitch">
            <span data-calc-bandwidth>—</span> <span class="text-[14px]">TB</span>
          </p>
        </div>
      </div>
    </div>

    {/* Contact prompt */}
    <div class="mt-[24px] flex flex-col items-center justify-center gap-[16px] md:flex-row">
      <p class="font-body text-[14px] font-medium text-white">
        {calculator.contact.prompt}
      </p>
      <a
        href={calculator.contact.cta.link}
        class="inline-flex items-center justify-center rounded-sm border border-white/30 bg-transparent px-[24px] py-[10px] font-body text-[14px] font-medium text-white transition-colors hover:bg-white/10"
      >
        {calculator.contact.cta.text}
      </a>
    </div>
  </div>

  {/* Tooltip floating element (single, repositioned) */}
  <div
    class="calc-tooltip pointer-events-none fixed z-[70] hidden max-w-65 rounded-[8px] bg-charcoal-pitch px-[12px] py-[8px] font-body text-[12px] leading-[1.4] text-white shadow-lg ring-1 ring-white/10"
    data-calc-tooltip
    role="tooltip"
  ></div>
</div>

<style>
  /* Calculator accent colour — switches per active product */
  .pricing-calc-modal[data-active-product='on-demand'] {
    --calc-accent: var(--color-blue-matchday);
  }
  .pricing-calc-modal[data-active-product='live'] {
    --calc-accent: var(--color-orange-basketball);
  }

  .pricing-calc-tab {
    background-color: rgb(255 255 255 / 0.05);
    color: rgb(255 255 255 / 0.5);
  }
  .pricing-calc-tab:hover {
    background-color: rgb(255 255 255 / 0.08);
  }
  .pricing-calc-tab.is-active[data-calc-tab='on-demand'] {
    background-color: var(--color-blue-matchday);
    color: white;
  }
  .pricing-calc-tab.is-active[data-calc-tab='live'] {
    background-color: var(--color-orange-basketball);
    color: white;
  }
  .pricing-calc-tab .calc-tab-label,
  .pricing-calc-tab .calc-tab-desc {
    color: inherit;
  }

  /* Plan recommendation text — uses active accent */
  .calc-plan-name {
    color: var(--calc-accent);
  }

  /* View Plan link follows the active product accent (DEV-2334) */
  .calc-view-plan {
    color: var(--calc-accent);
  }

  /* Output panel state — figures fade in once the user has touched
     all sliders (DEV-2284) */
  .calc-figures.is-ready {
    opacity: 1;
  }

  /* Range slider — fill + thumb both use --calc-accent */
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    background: rgb(255 255 255 / 0.15);
    border-radius: 999px;
    outline: none;
  }
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: white;
    border: 2px solid var(--slider-accent, var(--calc-accent));
    cursor: pointer;
  }
  .calc-slider::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: white;
    border: 2px solid var(--slider-accent, var(--calc-accent));
    cursor: pointer;
  }
  .calc-slider::-moz-range-track {
    height: 4px;
    border-radius: 999px;
  }
  .calc-slider::-moz-range-progress {
    height: 4px;
    background: var(--calc-accent);
    border-radius: 999px;
  }
</style>

<script>
  type ProductId = 'on-demand' | 'live';

  // Plan thresholds — tier index (0=Launch, 1=Growth, 2=Scale, 3=Unlimited).
  // Live thresholds updated per DEV-2330 to match the new tier figures
  // (15/20/30 hrs, 1/3/5/10TB+ bandwidth).
  // NB: still tentative — final algorithm pending Alex/Dawie (DEV-2286).
  const OD_BANDWIDTH_TB = [1, 5, 20, Infinity];
  const LIVE_BANDWIDTH_TB = [1, 3, 5, Infinity];
  const LIVE_HOURS = [15, 20, 30, Infinity];
  const TIER_NAMES = ['Launch Plan', 'Growth Plan', 'Scale Plan', 'Unlimited Plan'];

  // 1080p HLS averages ~5 Mbps. Bandwidth (GB) per fan-hour: 2.25.
  const GB_PER_FAN_HOUR_1080P = 2.25;
  // Per-subscriber on-demand watch-hour assumption (TBD with Alex/Dawie).
  const OD_HOURS_PER_SUBSCRIBER_PER_MONTH = 4;
  // Avg. minutes per uploaded video (impacts library bandwidth).
  const OD_AVG_VIDEO_MINUTES = 5;

  function pickTier(value: number, thresholds: number[]) {
    for (let i = 0; i < thresholds.length; i++) {
      if (value <= thresholds[i]) return i;
    }
    return thresholds.length - 1;
  }

  function initPricingCalculator() {
    const modal = document.querySelector<HTMLElement>('[data-calc-modal]');
    if (!modal) return;

    let activeProduct: ProductId = 'on-demand';
    // Per-product touched sets — only sliders for the active product
    // (excluding the optional Refine sub-group which is opt-in) need
    // to be touched before the recommendation reveals.
    const touched: Record<ProductId, Set<string>> = {
      'on-demand': new Set(),
      'live': new Set(),
    };

    // Closing the calculator cancels the current calculation — sliders
    // revert to defaults, touched sets clear, recommendation hides
    // (DEV-2333). The calculator opens fresh on every Calculate Usage click.
    const resetCalculator = () => {
      touched['on-demand'].clear();
      touched['live'].clear();
      // Snap all sliders back to their default values
      modal!.querySelectorAll<HTMLInputElement>('.calc-slider').forEach((s) => {
        const def = s.getAttribute('value');
        if (def !== null) s.value = def;
        updateSliderFill(s);
      });
      // Snap product back to On-Demand
      const tabs = modal!.querySelectorAll<HTMLButtonElement>('.pricing-calc-tab');
      tabs.forEach((t) => t.classList.toggle('is-active', t.dataset.calcTab === 'on-demand'));
      // Close any open Refine OD details
      modal!.querySelectorAll<HTMLDetailsElement>('details.calc-refine-od').forEach((d) => {
        d.open = false;
      });
      setActiveProduct('on-demand');
      // Recommendation visual on plan cards also clears
      clearRecommendation('on-demand');
      clearRecommendation('live');
    };

    const close = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      resetCalculator();
    };

    modal.querySelector('[data-calc-close]')?.addEventListener('click', close);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });

    // View Plan — closes the calculator and scrolls the pricing page so
    // the recommended plan card is in view (DEV-2334).
    modal.querySelector('[data-calc-view-plan]')?.addEventListener('click', () => {
      const productGrid = document.querySelector<HTMLElement>(
        `[data-product-grid="${activeProduct}"]`
      );
      // Ensure the right product tab is active on the pricing page
      const planTabs = document.querySelectorAll<HTMLButtonElement>('.pricing-product-tab');
      planTabs.forEach((t) => t.classList.toggle('is-active', t.dataset.productTab === activeProduct));
      document.querySelectorAll<HTMLElement>('[data-product-grid]').forEach((g) => {
        g.classList.toggle('hidden', g.dataset.productGrid !== activeProduct);
      });
      const plansSection = document.querySelector<HTMLElement>('.pricing-plans-section');
      if (plansSection) plansSection.dataset.activeProduct = activeProduct;
      // Close the modal but keep the recommendation visual on the cards
      // (don't reset — user wants to actually see the plan)
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Scroll the plans section into view
      const target = plansSection || productGrid;
      target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    function setActiveProduct(productId: ProductId) {
      activeProduct = productId;
      modal!.dataset.activeProduct = productId;
      // Show only the matching slider set
      modal!.querySelectorAll<HTMLElement>('[data-product-sliders]').forEach((el) => {
        el.classList.toggle('hidden', el.dataset.productSliders !== productId);
      });
      // Toggle the Hours figure visibility — only relevant for Live (DEV-2330)
      const hoursFigure = modal!.querySelector<HTMLElement>('[data-calc-figure="hours"]');
      hoursFigure?.classList.toggle('hidden', productId !== 'live');
      // Restyle visible sliders with new accent colour
      modal!.querySelectorAll<HTMLInputElement>('.calc-slider').forEach(updateSliderFill);
      recompute();
    }

    const tabs = modal.querySelectorAll<HTMLButtonElement>('.pricing-calc-tab');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = (tab.dataset.calcTab as ProductId) || 'on-demand';
        tabs.forEach((t) => t.classList.toggle('is-active', t === tab));
        setActiveProduct(id);
      });
    });

    function requiredSliderIdsFor(productId: ProductId): string[] {
      const visible = modal!.querySelector<HTMLElement>(`[data-product-sliders="${productId}"]`);
      if (!visible) return [];
      return Array.from(
        visible.querySelectorAll<HTMLInputElement>('.calc-slider:not([data-slider-refine])')
      ).map((el) => el.dataset.slider!).filter(Boolean);
    }

    // Sliders — track touched state per product, recompute on input.
    const allSliders = modal.querySelectorAll<HTMLInputElement>('.calc-slider');
    allSliders.forEach((s) => {
      updateSliderFill(s);
      s.addEventListener('input', () => {
        const id = s.dataset.slider;
        const productScope = (s.dataset.sliderProduct as ProductId) || activeProduct;
        if (id) touched[productScope].add(id);
        updateSliderFill(s);
        recompute();
      });
    });

    function updateSliderFill(slider: HTMLInputElement) {
      const min = parseFloat(slider.min);
      const max = parseFloat(slider.max);
      const val = parseFloat(slider.value);
      const pct = ((val - min) / (max - min)) * 100;
      // Refine On-Demand sliders are always OD content, so they take the
      // OD (blue) accent regardless of which product tab is active.
      // DEV-2332 — Natalia wants OD sliders blue, not orange.
      const isRefineOd = slider.dataset.sliderRefine === 'true';
      const useLiveAccent = activeProduct === 'live' && !isRefineOd;
      const accent = useLiveAccent
        ? 'var(--color-orange-basketball)'
        : 'var(--color-blue-matchday)';
      slider.style.background = `linear-gradient(to right, ${accent} 0%, ${accent} ${pct}%, rgb(255 255 255 / 0.15) ${pct}%, rgb(255 255 255 / 0.15) 100%)`;
      // Track the slider's individual accent so its thumb border updates too
      slider.style.setProperty('--slider-accent', accent);
    }

    function readSlider(id: string, scopeRefine = false): number {
      const sel = `.calc-product-sliders[data-product-sliders="${activeProduct}"]:not(.hidden) input[data-slider="${id}"]${
        scopeRefine ? '[data-slider-refine]' : ':not([data-slider-refine])'
      }`;
      const el = modal!.querySelector<HTMLInputElement>(sel);
      return el ? parseFloat(el.value || '0') : 0;
    }

    function recompute() {
      const required = requiredSliderIdsFor(activeProduct);
      const allTouched = required.length > 0 && required.every((id) => touched[activeProduct].has(id));

      // Toggle empty state vs recommendation + figures
      const emptyEl = modal!.querySelector<HTMLElement>('[data-calc-empty]');
      const recEl = modal!.querySelector<HTMLElement>('[data-calc-recommendation]');
      const figsEl = modal!.querySelector<HTMLElement>('[data-calc-figures]');
      emptyEl?.classList.toggle('hidden', allTouched);
      recEl?.classList.toggle('hidden', !allTouched);
      figsEl?.classList.toggle('is-ready', allTouched);

      let liveHours = 0;
      let totalBandwidthTB = 0;
      let tierIdx = 0;

      if (activeProduct === 'on-demand') {
        const subscribers = readSlider('estimated-subscribers');
        const videosPerWeek = readSlider('videos-per-week');
        // Library bandwidth from uploaded videos consumed by subscribers.
        // TENTATIVE — final formula pending Alex/Dawie (DEV-2286).
        const monthlyVideoHours = (videosPerWeek * 4 * OD_AVG_VIDEO_MINUTES) / 60;
        const watchHoursPerMonth = subscribers * OD_HOURS_PER_SUBSCRIBER_PER_MONTH;
        totalBandwidthTB = (watchHoursPerMonth * GB_PER_FAN_HOUR_1080P) / 1024;
        // OD has no live hours — keep 0; the figure still displays.
        liveHours = monthlyVideoHours;
        tierIdx = pickTier(totalBandwidthTB, OD_BANDWIDTH_TB);
      } else {
        const length = readSlider('stream-length');
        const fans = readSlider('fans-per-stream');
        const streams = readSlider('streams-per-month');
        liveHours = length * streams;
        const liveBwTB = (liveHours * fans * GB_PER_FAN_HOUR_1080P) / 1024;
        // Optional Refine OD inputs add to total bandwidth if user has
        // opened/touched them; otherwise default 1.3x replay multiplier.
        const refineSubs = readSlider('estimated-subscribers', true);
        const refineVideos = readSlider('videos-per-week', true);
        const refineTouched = touched['live'].has('estimated-subscribers')
          || touched['live'].has('videos-per-week');
        const odBwTB = refineTouched
          ? (refineSubs * OD_HOURS_PER_SUBSCRIBER_PER_MONTH * GB_PER_FAN_HOUR_1080P) / 1024
            + (refineVideos * 4 * OD_AVG_VIDEO_MINUTES * GB_PER_FAN_HOUR_1080P) / (60 * 1024)
          : liveBwTB * 0.3;
        totalBandwidthTB = liveBwTB + odBwTB;
        const bwTier = pickTier(totalBandwidthTB, LIVE_BANDWIDTH_TB);
        const hoursTier = pickTier(liveHours, LIVE_HOURS);
        tierIdx = Math.max(bwTier, hoursTier);
      }

      const hoursEl = modal!.querySelector('[data-calc-hours]');
      const bwEl = modal!.querySelector('[data-calc-bandwidth]');
      const planEl = modal!.querySelector('[data-calc-plan]');
      if (hoursEl) hoursEl.textContent = allTouched ? String(Math.round(liveHours)) : '—';
      if (bwEl) bwEl.textContent = allTouched ? totalBandwidthTB.toFixed(1) : '—';
      if (planEl) planEl.textContent = TIER_NAMES[tierIdx];

      if (allTouched) applyRecommendation(activeProduct, tierIdx);
      else clearRecommendation(activeProduct);
    }

    function applyRecommendation(productId: ProductId, tierIdx: number) {
      const grid = document.querySelector<HTMLElement>(`[data-product-grid="${productId}"]`);
      if (!grid) return;
      const ringClass = productId === 'on-demand' ? 'ring-blue-matchday' : 'ring-orange-basketball';
      const cards = grid.querySelectorAll<HTMLElement>('.pricing-plan-card');
      cards.forEach((card) => {
        const isMatch = Number(card.dataset.tierIndex) === tierIdx;
        const recommended = card.querySelector<HTMLElement>('.pricing-tag-recommended');
        const popular = card.querySelector<HTMLElement>('.pricing-tag-popular');
        recommended?.classList.toggle('hidden', !isMatch);
        popular?.classList.add('hidden');
        card.classList.toggle(ringClass, isMatch);
        card.classList.toggle('ring-white/10', !isMatch);
      });
    }

    function clearRecommendation(productId: ProductId) {
      const grid = document.querySelector<HTMLElement>(`[data-product-grid="${productId}"]`);
      if (!grid) return;
      grid.querySelectorAll<HTMLElement>('.pricing-tag-recommended').forEach((el) => el.classList.add('hidden'));
      grid.querySelectorAll<HTMLElement>('.pricing-tag-popular').forEach((el) => el.classList.remove('hidden'));
    }

    setActiveProduct('on-demand');

    // Tooltips — single floating element, positioned next to the trigger
    const tooltip = modal.querySelector<HTMLElement>('[data-calc-tooltip]');
    if (!tooltip) return;
    const triggers = modal.querySelectorAll<HTMLButtonElement>('.calc-tooltip-trigger');

    function show(trigger: HTMLElement) {
      const text = trigger.dataset.tooltip;
      if (!text || !tooltip) return;
      tooltip.textContent = text;
      tooltip.classList.remove('hidden');
      const rect = trigger.getBoundingClientRect();
      const tipRect = tooltip.getBoundingClientRect();
      let top = rect.bottom + 8;
      let left = rect.left + rect.width / 2 - tipRect.width / 2;
      if (left < 8) left = 8;
      if (left + tipRect.width > window.innerWidth - 8) {
        left = window.innerWidth - tipRect.width - 8;
      }
      tooltip.style.top = `${top}px`;
      tooltip.style.left = `${left}px`;
    }

    function hide() {
      tooltip?.classList.add('hidden');
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('mouseenter', () => show(trigger));
      trigger.addEventListener('mouseleave', hide);
      trigger.addEventListener('focus', () => show(trigger));
      trigger.addEventListener('blur', hide);
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (tooltip!.classList.contains('hidden')) show(trigger);
        else hide();
      });
    });
  }

  document.addEventListener('astro:page-load', initPricingCalculator);
  initPricingCalculator();
</script>
