---
import type { PricingHeroData, PricingProduct } from '../../types/content';
import PricingPlanCard from './PricingPlanCard.astro';

interface Props {
  hero: PricingHeroData;
  products: PricingProduct[];
}

const { hero, products } = Astro.props;
---

{/* Sticky wrapper — sticks below the nav (88px) and stays as the user
    scrolls past into the comparison table (parent in pricing.astro
    extends the sticky context). */}
<section class="pricing-plans-section sticky top-[88px] z-20 bg-charcoal-pitch shadow-[0px_4px_20px_0px_rgba(0,0,0,0.4)]">
  <div class="mx-auto flex max-w-300 flex-col gap-[24px] px-[24px] py-[24px] md:gap-[32px] md:px-[64px] md:py-[32px]">
    {/* Product tab cards */}
    <div class="grid grid-cols-1 gap-[16px] md:grid-cols-2 md:gap-[24px]">
      {products.map((product, i) => (
        <button
          type="button"
          class={`pricing-product-tab group flex flex-col items-center gap-[8px] rounded-[16px] px-[24px] py-[16px] text-center transition-colors md:py-[24px] ${i === 0 ? 'is-active' : ''}`}
          data-product-tab={product.id}
        >
          <span class="product-tab-label text-h4">
            {product.tabLabel}
          </span>
          <span class="product-tab-desc max-w-110 text-body">
            {product.description}
          </span>
        </button>
      ))}
    </div>

    {/* Billing toggle */}
    <div class="flex items-center justify-center gap-[16px]">
      <span class="billing-label text-body font-medium text-white" data-billing-label="monthly">
        {hero.billingToggle.monthlyLabel}
      </span>
      <button
        type="button"
        class="billing-toggle relative flex h-[24px] w-[44px] items-center rounded-full bg-white/15 transition-colors"
        role="switch"
        aria-checked="false"
        data-billing-toggle
      >
        <span class="billing-thumb absolute left-[2px] h-[20px] w-[20px] rounded-full bg-orange-basketball transition-transform"></span>
      </button>
      <span class="billing-label text-body font-medium text-white/60" data-billing-label="annual">
        {hero.billingToggle.annualLabel}
      </span>
    </div>

    {/* Plan cards — one grid per product, only the active one shown */}
    {products.map((product, i) => (
      <div
        class={`pricing-plan-grid grid grid-cols-1 gap-[16px] sm:grid-cols-2 lg:grid-cols-4 md:gap-[24px] ${i === 0 ? '' : 'hidden'}`}
        data-product-grid={product.id}
      >
        {product.tiers.map((tier, idx) => (
          <PricingPlanCard tier={tier} productId={product.id} tierIndex={idx} />
        ))}
      </div>
    ))}

    {/* Subtext below cards */}
    {hero.cardsSubtext && hero.cardsSubtext.length > 0 && (
      <div class="flex flex-col gap-[4px] text-center">
        {hero.cardsSubtext.map((line) => (
          <p class="text-body text-white/60">{line}</p>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /* Product tab visual states */
  .pricing-product-tab {
    background-color: rgb(255 255 255 / 0.05);
    color: rgb(255 255 255 / 0.5);
  }
  .pricing-product-tab:hover {
    background-color: rgb(255 255 255 / 0.08);
  }
  .pricing-product-tab.is-active[data-product-tab='on-demand'] {
    background-color: var(--color-blue-matchday);
    color: white;
  }
  .pricing-product-tab.is-active[data-product-tab='live'] {
    background-color: var(--color-orange-basketball);
    color: white;
  }
  .pricing-product-tab .product-tab-label,
  .pricing-product-tab .product-tab-desc {
    color: inherit;
  }

  /* Billing toggle thumb position */
  .billing-toggle[aria-checked='true'] .billing-thumb {
    transform: translateX(20px);
  }

  /* When sticky and scrolled, compress the section to give comparison
     more room. .is-condensed is set by JS via IntersectionObserver. */
  .pricing-plans-section.is-condensed .pricing-product-tab {
    padding-top: 8px;
    padding-bottom: 8px;
  }
  .pricing-plans-section.is-condensed .product-tab-desc {
    display: none;
  }
</style>

<script>
  function initPricingPlansSection() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.pricing-product-tab');
    const grids = document.querySelectorAll<HTMLElement>('[data-product-grid]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const productId = tab.dataset.productTab;
        if (!productId) return;
        tabs.forEach((t) => t.classList.toggle('is-active', t.dataset.productTab === productId));
        grids.forEach((g) =>
          g.classList.toggle('hidden', g.dataset.productGrid !== productId)
        );
      });
    });

    const toggle = document.querySelector<HTMLButtonElement>('[data-billing-toggle]');
    if (toggle) {
      const monthlyLabel = document.querySelector<HTMLElement>('[data-billing-label="monthly"]');
      const annualLabel = document.querySelector<HTMLElement>('[data-billing-label="annual"]');

      toggle.addEventListener('click', () => {
        const isAnnual = toggle.getAttribute('aria-checked') === 'true';
        const next = !isAnnual;
        toggle.setAttribute('aria-checked', String(next));

        monthlyLabel?.classList.toggle('text-white', !next);
        monthlyLabel?.classList.toggle('text-white/60', next);
        annualLabel?.classList.toggle('text-white', next);
        annualLabel?.classList.toggle('text-white/60', !next);

        document.querySelectorAll<HTMLElement>('.pricing-price').forEach((el) => {
          const v = next ? el.dataset.annual : el.dataset.monthly;
          if (v) el.textContent = v;
        });
        document.querySelectorAll<HTMLElement>('.pricing-price-strike').forEach((el) => {
          const v = next ? el.dataset.annualStrike : el.dataset.monthlyStrike;
          if (v) el.textContent = v;
          el.classList.toggle('opacity-0', !next);
        });
        document.querySelectorAll<HTMLElement>('.pricing-price-vat').forEach((el) => {
          const v = next ? el.dataset.annualVat : el.dataset.monthlyVat;
          if (v) el.textContent = v;
        });
      });

      // Initial: monthly selected, hide strike-through
      document
        .querySelectorAll<HTMLElement>('.pricing-price-strike')
        .forEach((el) => el.classList.add('opacity-0'));
    }

    // Calculator trigger — opens modal (handled by calculator script if mounted)
    const calcTriggers = document.querySelectorAll<HTMLButtonElement>('[data-calc-trigger]');
    calcTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const modal = document.querySelector<HTMLElement>('[data-calc-modal]');
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    // Detect when the plans section becomes "stuck" (sticky position
    // engaged) and condense the layout to give content below more room.
    const section = document.querySelector<HTMLElement>('.pricing-plans-section');
    if (section) {
      // Sentinel placed just before the section to detect when it sticks
      const sentinel = document.createElement('div');
      sentinel.style.cssText = 'position:absolute;top:-1px;left:0;right:0;height:1px;pointer-events:none;';
      section.parentElement?.insertBefore(sentinel, section);
      const observer = new IntersectionObserver(
        ([entry]) => {
          section.classList.toggle('is-condensed', !entry.isIntersecting);
        },
        { threshold: 0, rootMargin: '-88px 0px 0px 0px' }
      );
      observer.observe(sentinel);
    }
  }

  document.addEventListener('astro:page-load', initPricingPlansSection);
  initPricingPlansSection();
</script>
