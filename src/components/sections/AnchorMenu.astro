---
import type { AnchorItem } from '../../types/content';

interface Props {
  anchors: AnchorItem[];
}

const { anchors } = Astro.props;
---

<nav
  class="anchor-menu sticky top-0 z-40 bg-navy-umpire shadow-[0px_4px_13px_0px_rgba(22,29,37,0.1),0px_3px_38px_0px_rgba(0,0,0,0.05)] lg:z-50"
  aria-label="Feature sections"
  data-anchor-menu
  data-sticky-mode="down"
>
  <div class="mx-auto flex max-w-360 items-stretch">
    {/* Scrollable anchors on mobile, flex on desktop */}
    <div class="flex flex-1 items-stretch overflow-x-auto scrollbar-hide">
      {anchors.map((anchor, i) => (
        <a
          href={`#${anchor.id}`}
          class="anchor-link flex shrink-0 cursor-pointer items-center justify-center border-b-4 border-grey px-[12px] py-[16px] font-subheading text-[14px] font-medium uppercase leading-none tracking-[-0.48px] text-white whitespace-nowrap transition-colors md:flex-1 md:border-b-8 md:px-[8px] md:py-[24px] md:text-[18px] md:tracking-[-0.6px] lg:text-[20px]"
          data-anchor={anchor.id}
          data-active={i === 0 ? 'true' : undefined}
        >
          {anchor.label}
        </a>
      ))}
    </div>

    {/* Book A Call button */}
    <div class="hidden shrink-0 items-center border-b-8 border-grey p-[24px] md:flex">
      <a
        href="/contact"
        class="inline-flex h-10.5 items-center justify-center rounded-sm bg-blue-matchday px-[24px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-white transition-colors hover:bg-blue-matchday/90"
      >
        Book A Call
      </a>
    </div>
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  /* DEV-2345 — suppress the default browser focus ring on anchor links so
     they don't flash with outlines while the menu is mounting. Keyboard
     users still get the active-state colour change. */
  .anchor-link {
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  .anchor-link:focus,
  .anchor-link:focus-visible {
    outline: none;
    box-shadow: none;
  }
  .anchor-link[data-active="true"] {
    border-color: var(--color-yellow-tennis) !important;
    color: var(--color-yellow-tennis);
  }

  /* Directional sticky (desktop). The anchor menu stays sticky as the
     user scrolls DOWN; once they scroll UP we drop it back to static so
     the main header can take over the top of the viewport and the user
     doesn't have to scroll all the way to the top to reach other pages. */
  .anchor-menu[data-sticky-mode="up"] {
    position: static;
  }
</style>

<script>
  function initAnchorMenu() {
    const anchors = document.querySelectorAll<HTMLAnchorElement>('.anchor-link');
    const sections = new Map<string, HTMLElement>();

    anchors.forEach((anchor) => {
      const id = anchor.dataset.anchor;
      if (id) {
        const section = document.getElementById(id);
        if (section) sections.set(id, section);
      }
    });

    function updateActive() {
      const scrollY = window.scrollY + 200;
      let activeId = '';

      sections.forEach((section, id) => {
        const top = section.offsetTop;
        const bottom = top + section.offsetHeight;
        if (scrollY >= top && scrollY < bottom) {
          activeId = id;
        }
      });

      // DEV-2345 — when no section is currently in view (eg. page just
      // loaded above the first section), fall back to the first anchor
      // so the menu never renders with every link in its inactive grey
      // border state.
      if (!activeId && anchors.length > 0) {
        activeId = anchors[0]!.dataset.anchor || '';
      }

      anchors.forEach((anchor) => {
        const id = anchor.dataset.anchor;
        if (id === activeId) {
          anchor.setAttribute('data-active', 'true');
        } else {
          anchor.removeAttribute('data-active');
        }
      });
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();

    // Header / anchor-menu interaction.
    // - Mobile (<lg): header always visible, anchor menu sticky-offsets
    //   below the header so the hamburger stays reachable (DEV-2343).
    // - Desktop (>=lg): DIRECTIONAL sticky. Scroll DOWN past the anchor
    //   menu and it sticks at the top while the header slides up out of
    //   the way (current behaviour). Scroll UP and we DROP the anchor
    //   menu's sticky behaviour and bring the header back into view, so
    //   the user can reach other pages without scrolling all the way
    //   back to the top.
    const anchorMenu = document.querySelector<HTMLElement>('[data-anchor-menu]');
    const siteHeader = document.querySelector<HTMLElement>('.site-header');
    if (anchorMenu && siteHeader) {
      const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

      const applyMobileOffset = () => {
        if (isDesktop()) {
          anchorMenu.style.top = '0px';
          return;
        }
        const headerH = siteHeader.getBoundingClientRect().height;
        anchorMenu.style.top = `${headerH}px`;
      };

      // Track scroll position + direction. A small threshold avoids
      // flicker on momentum-scroll jitter.
      let lastY = window.scrollY;
      let lastDirection: 'up' | 'down' = 'down';
      const DIRECTION_THRESHOLD = 6;

      const update = () => {
        if (!isDesktop()) {
          // Mobile path: header always shown, sticky mode irrelevant.
          siteHeader.classList.remove('-translate-y-full');
          anchorMenu.dataset.stickyMode = 'down';
          lastY = window.scrollY;
          return;
        }

        const y = window.scrollY;
        const delta = y - lastY;
        if (Math.abs(delta) > DIRECTION_THRESHOLD) {
          lastDirection = delta > 0 ? 'down' : 'up';
          lastY = y;
        }

        // Where the anchor menu naturally sits in the document.
        const anchorNaturalTop = anchorMenu.offsetTop;
        const scrolledPastAnchor = y >= anchorNaturalTop;

        if (lastDirection === 'down') {
          // Scrolling DOWN — current behaviour.
          anchorMenu.dataset.stickyMode = 'down';
          siteHeader.classList.toggle('-translate-y-full', scrolledPastAnchor);
        } else {
          // Scrolling UP — drop anchor sticky so the header takes over
          // the top of the viewport. The anchor menu falls back to its
          // natural document position and scrolls away normally.
          anchorMenu.dataset.stickyMode = 'up';
          siteHeader.classList.remove('-translate-y-full');
        }
      };

      applyMobileOffset();
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', () => {
        applyMobileOffset();
        update();
      });
    }

    // Smooth scroll on click
    anchors.forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const id = anchor.dataset.anchor;
        if (!id) return;
        const section = sections.get(id);
        if (!section) return;
        const menuHeight = document.querySelector('.anchor-menu')?.getBoundingClientRect().height || 90;
        const top = section.offsetTop - menuHeight;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });
  }

  document.addEventListener('astro:page-load', initAnchorMenu);
  initAnchorMenu();
</script>
