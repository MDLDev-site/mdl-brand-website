---
import type { FeatureSection } from '../../types/content';

interface Props {
  section: FeatureSection;
}

const { section } = Astro.props;
const isImageLeft = section.imagePosition === 'left';
---

<section class="bg-grey" aria-label={section.heading}>
  <div class:list={[
    'mx-auto flex max-w-[1440px] flex-col md:flex-row',
    isImageLeft && 'md:flex-row-reverse',
  ]}>
    {/* Content side */}
    <div class="flex flex-1 flex-col justify-center gap-[32px] px-[24px] py-[80px] md:py-[140px] md:pl-[120px] md:pr-[64px]">
      <h2 class="font-heading text-[40px] font-medium uppercase leading-[0.9] tracking-[-1.8px] text-charcoal-pitch md:text-[60px]">
        {section.heading}
      </h2>

      <p class="max-w-[500px] font-body text-[18px] font-normal leading-[1.4] text-text-primary">
        {section.description}
      </p>

      {section.features.length > 0 && (
        <ul class="flex flex-col gap-[16px]" role="list">
          {section.features.map((feature) => (
            <li class="flex items-center gap-[12px]">
              <span
                class="flex h-[24px] w-[24px] shrink-0 items-center justify-center rounded-full bg-green-600"
                aria-hidden="true"
              >
                <svg class="h-[14px] w-[14px] text-white" viewBox="0 0 14 14" fill="none">
                  <path d="M2.5 7l3 3 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="font-body text-[14px] font-normal leading-[1.5] text-charcoal-pitch">
                {feature.text}
              </span>
            </li>
          ))}
        </ul>
      )}

      <div class="flex flex-col gap-[16px] pt-[8px] sm:flex-row sm:items-center sm:gap-[24px]">
        <a
          href={section.cta.primary.link}
          class="inline-flex items-center rounded-[4px] bg-blue-matchday px-[32px] py-[16px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-white transition-colors hover:bg-blue-matchday/90"
        >
          {section.cta.primary.text}
        </a>

        <a
          href={section.cta.secondary.link}
          class="group inline-flex items-center gap-[8px] font-body text-[16px] font-medium capitalize leading-[1.1] tracking-[0.32px] text-charcoal-pitch transition-colors hover:text-blue-matchday"
        >
          {section.cta.secondary.text}
          <svg
            class="h-[16px] w-[16px] transition-transform group-hover:translate-x-[4px]"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>

    {/* Image side */}
    <div class="relative flex flex-1 items-center justify-center overflow-clip bg-grey">
      {section.image ? (
        <img
          src={section.image}
          alt={section.imageAlt}
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="flex h-[400px] w-full items-center justify-center bg-charcoal-pitch/5 md:h-full"
          role="img"
          aria-label={section.imageAlt}
        >
          <span class="font-body text-[14px] text-charcoal-pitch/30">Feature Image</span>
        </div>
      )}
    </div>
  </div>
</section>
