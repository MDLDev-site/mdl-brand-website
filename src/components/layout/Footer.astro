---
import type { Navigation } from '../../types/content';

interface Props {
  brand: Navigation['brand'];
}

const { brand } = Astro.props;

const footerColumns = [
  {
    title: 'Features',
    links: [
      { text: 'Platform', href: '#platform' },
      { text: 'Brandability', href: '#brandability' },
      { text: 'Monetisation', href: '#monetisation' },
      { text: 'Insights', href: '#insights' },
      { text: 'Fan experience', href: '#fan-experience' },
      { text: 'Scalability', href: '#scalability' },
      { text: 'Security', href: '#security' },
    ],
  },
  {
    title: 'Products',
    links: [
      { text: 'On-Demand', href: '#on-demand' },
      { text: 'Live & On-Demand', href: '#live-on-demand' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { text: 'About', href: '/about' },
      { text: 'Pricing', href: '#pricing' },
      { text: 'Live Estimator Calculator', href: '#estimator' },
    ],
  },
  {
    title: 'Help',
    links: [
      { text: 'Contact', href: '/contact' },
    ],
  },
];

const socialLinks = [
  {
    name: 'X',
    href: 'https://x.com/matchdaylive',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    name: 'Instagram',
    href: 'https://instagram.com/matchdaylive',
    icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>`,
  },
  {
    name: 'YouTube',
    href: 'https://youtube.com/matchdaylive',
    icon: `<path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>`,
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com/company/matchdaylive',
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
];
---

<footer class="bg-charcoal-pitch px-[24px] py-[64px] md:px-30 md:py-30">
  <div class="mx-auto flex max-w-360 flex-col gap-[48px] md:gap-[64px]">
    {/* Link columns — desktop: grid, mobile: accordion */}
    <div class="hidden gap-10 md:grid md:grid-cols-4">
      {footerColumns.map((column) => (
        <div>
          <h3 class="pb-[16px] font-subheading text-[18px] font-semibold uppercase text-yellow-tennis">
            {column.title}
          </h3>
          <ul class="flex flex-col gap-[12px]" role="list">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-[16px] font-normal leading-[1.4] text-white transition-colors hover:text-yellow-tennis"
                >
                  {link.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* Mobile accordion footer */}
    <div class="flex flex-col md:hidden" id="footer-accordion">
      {footerColumns.map((column, idx) => (
        <div class="border-b border-white/10">
          <button
            class="flex w-full items-center justify-between py-[16px] text-left"
            type="button"
            aria-expanded="false"
            data-footer-toggle={idx}
          >
            <span class="font-subheading text-[16px] font-semibold uppercase text-yellow-tennis">
              {column.title}
            </span>
            <svg class="h-5 w-5 text-white/60 transition-transform" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div class="max-h-0 overflow-hidden transition-all duration-300" data-footer-panel={idx}>
            <ul class="flex flex-col gap-[12px] pb-[16px]" role="list">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="font-body text-[14px] font-normal leading-normal text-white transition-colors hover:text-yellow-tennis"
                  >
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    {/* Bottom bar */}
    <div class="flex flex-col items-center gap-[24px] border-t border-white/10 pt-[32px] md:flex-row md:justify-between">
      {/* Logo + copyright */}
      <div class="flex flex-col items-center gap-[8px] md:flex-row md:gap-[12px]">
        <a href="/" class="shrink-0">
          <img src="/logo.svg" alt={brand.name} class="h-5 w-auto" />
        </a>
        <div class="flex items-center gap-[4px] text-center">
          <span class="font-body text-[14px] font-normal text-white md:text-[16px]">
            &copy; Matchday Media. All rights reserved
          </span>
          <span class="text-white/40">&bull;</span>
          <a
            href="/legal"
            class="font-body text-[14px] font-normal text-white transition-colors hover:text-yellow-tennis md:text-[16px]"
          >
            Legal
          </a>
        </div>
      </div>

      {/* Social icons */}
      <div class="flex items-center gap-[12px]">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            class="flex h-10 w-10 items-center justify-center rounded-full bg-yellow-tennis p-[8px] transition-opacity hover:opacity-80"
            aria-label={social.name}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              class="h-5 w-5 text-charcoal-pitch"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <Fragment set:html={social.icon} />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<script>
  function initFooterAccordion() {
    const toggles = document.querySelectorAll('[data-footer-toggle]');
    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const idx = toggle.getAttribute('data-footer-toggle');
        const panel = document.querySelector(`[data-footer-panel="${idx}"]`) as HTMLElement;
        const chevron = toggle.querySelector('svg');
        if (!panel) return;

        const isOpen = panel.classList.contains('max-h-[300px]');
        if (isOpen) {
          panel.classList.remove('max-h-[300px]');
          panel.classList.add('max-h-0');
          toggle.setAttribute('aria-expanded', 'false');
          chevron?.classList.remove('rotate-180');
        } else {
          panel.classList.add('max-h-[300px]');
          panel.classList.remove('max-h-0');
          toggle.setAttribute('aria-expanded', 'true');
          chevron?.classList.add('rotate-180');
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initFooterAccordion);
  initFooterAccordion();
</script>
