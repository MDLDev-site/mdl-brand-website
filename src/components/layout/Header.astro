---
import type { Navigation } from '../../types/content';

interface Props {
  nav: Navigation;
}

const { nav } = Astro.props;

const navLinks = [
  { text: 'Products', href: '#products', hasDropdown: true },
  { text: 'Features', href: '/features', hasDropdown: false },
  { text: 'Solution', href: '#solution', hasDropdown: true },
  { text: 'Pricing', href: '/pricing', hasDropdown: false },
];
---

<header class="site-header fixed top-0 left-0 right-0 z-50 bg-transparent p-[16px] transition-[translate] duration-200">
  <div class="relative mx-auto max-w-360">
    <nav
      class="relative z-50 flex items-center justify-between rounded-[16px] bg-[rgba(22,29,37,0.9)] px-[24px] py-[12px] backdrop-blur-md"
      aria-label="Main navigation"
    >
      <!-- Logo -->
      <a href="/" class="shrink-0">
        <img src="/logo.svg" alt={nav.brand.name} class="h-[24px] w-auto" />
      </a>

      <!-- Center links -->
      <ul class="hidden items-center gap-[4px] lg:flex" role="list">
        {navLinks.map((link) => (
          <li class="relative">
            {link.hasDropdown ? (
              <button
                type="button"
                class="nav-dropdown-trigger flex items-center gap-[4px] rounded-md px-[8px] py-[4px] text-body-lg font-medium capitalize tracking-[-0.16px] text-white transition-colors hover:bg-white/10"
                data-dropdown={link.text.toLowerCase()}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.text}
                <svg
                  class="h-[16px] w-[16px] opacity-70 transition-transform"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            ) : (
              <a
                href={link.href}
                class="flex items-center gap-[4px] rounded-md px-[8px] py-[4px] text-body-lg font-medium capitalize tracking-[-0.16px] text-white transition-colors hover:bg-white/10"
              >
                {link.text}
              </a>
            )}
          </li>
        ))}
      </ul>

      <!-- Right buttons (DEV-2273: 12px 24px padding, case-sensitive, tracking -2%) -->
      <div class="hidden items-center gap-[12px] lg:flex">
        <a
          href="/sign-in"
          class="rounded-sm border border-white px-[24px] py-[12px] text-body-lg font-medium tracking-[-0.32px] text-white transition-colors hover:bg-white/10"
        >
          Sign in
        </a>
        <a
          href="/contact"
          class="rounded-sm bg-blue-matchday px-[24px] py-[12px] text-body-lg font-medium tracking-[-0.32px] text-white transition-colors hover:bg-blue-matchday/90"
        >
          Book a call
        </a>
      </div>

      <!-- Mobile menu button (DEV-2272: round, white stroke, both states) -->
      <button
        class="mobile-menu-trigger flex h-[40px] w-[40px] items-center justify-center rounded-full border border-white text-white transition-colors hover:bg-white/10 lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        type="button"
      >
        <svg class="hamburger-icon h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="close-icon hidden h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>

    <!-- Mobile menu panel (DEV-2271: full viewport, charcoal-pitch bg per DEV-2298; DEV-2270: products dropdown inline) -->
    <div
      id="mobile-menu-panel"
      class="mobile-menu-panel pointer-events-none fixed inset-0 z-40 overflow-y-auto bg-charcoal-pitch opacity-0 transition-opacity duration-200 lg:hidden"
      aria-hidden="true"
    >
      <div class="flex min-h-full flex-col gap-[24px] px-[24px] pb-[40px] pt-[88px]">
        <ul class="flex flex-col" role="list">
          <!-- Products with inline expandable dropdown (DEV-2270) -->
          <li class="border-b border-white/10">
            <button
              type="button"
              class="mobile-products-trigger flex w-full items-center gap-[8px] py-[20px] text-left text-body-lg font-medium capitalize text-white"
              aria-expanded="false"
              aria-controls="mobile-products-panel"
            >
              Products
              <svg
                class="mobile-products-chevron h-[20px] w-[20px] transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div
              id="mobile-products-panel"
              class="mobile-products-panel accordion-collapsed overflow-hidden transition-[max-height] duration-300"
            >
              <div class="flex flex-col gap-[16px] pb-[20px]">
                <!-- On-Demand -->
                <div class="flex flex-col gap-[12px] rounded-[12px] border border-white/10 p-[20px]">
                  <div class="flex items-center gap-[12px]">
                    <img src="/images/icons/product-vod.svg" alt="" class="h-[28px] w-[28px]" aria-hidden="true" />
                    <h4 class="text-h5 text-white">On-Demand</h4>
                  </div>
                  <p class="text-body text-white/80">
                    From match replays to exclusive interviews, control how your content is organised, published, and monetised all from one platform.
                  </p>
                  <a
                    href="/pricing"
                    class="group inline-flex items-center gap-[8px] text-body font-medium text-yellow-tennis transition-colors hover:text-yellow-tennis/80"
                  >
                    Learn more
                    <svg class="h-[14px] w-[14px] transition-transform group-hover:translate-x-[4px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </a>
                </div>
                <!-- Live & On-Demand -->
                <div class="flex flex-col gap-[12px] rounded-[12px] border border-white/10 p-[20px]">
                  <div class="flex items-center gap-[12px]">
                    <img src="/images/icons/product-live.svg" alt="" class="h-[24px] w-[24px]" aria-hidden="true" />
                    <h4 class="text-h5 text-white">Live & On-Demand</h4>
                  </div>
                  <p class="text-body text-white/80">
                    Deliver smooth, low-latency live broadcasts with professional-grade quality whether it's a packed stadium or a behind-the-scenes moment.
                  </p>
                  <a
                    href="/pricing"
                    class="group inline-flex items-center gap-[8px] text-body font-medium text-yellow-tennis transition-colors hover:text-yellow-tennis/80"
                  >
                    Learn more
                    <svg class="h-[14px] w-[14px] transition-transform group-hover:translate-x-[4px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </li>

          <!-- Other top-level links -->
          <li class="border-b border-white/10">
            <a href="/features" class="block py-[20px] text-body-lg font-medium capitalize text-white">Features</a>
          </li>
          <li class="border-b border-white/10">
            <a href="/pricing" class="block py-[20px] text-body-lg font-medium capitalize text-white">Solution</a>
          </li>
          <li class="border-b border-white/10">
            <a href="/pricing" class="block py-[20px] text-body-lg font-medium capitalize text-white">Pricing</a>
          </li>
        </ul>

        <div class="mt-auto flex flex-col gap-[12px] pt-[24px]">
          <a
            href="/sign-in"
            class="rounded-sm border border-white px-[24px] py-[12px] text-center text-body-lg font-medium tracking-[-0.32px] text-white transition-colors hover:bg-white/10"
          >
            Sign in
          </a>
          <a
            href="/contact"
            class="rounded-sm bg-blue-matchday px-[24px] py-[12px] text-center text-body-lg font-medium tracking-[-0.32px] text-white transition-colors hover:bg-blue-matchday/90"
          >
            Book a call
          </a>
        </div>
      </div>
    </div>

    <!-- Products dropdown panel (desktop) -->
    <div
      class="nav-dropdown-panel pointer-events-none absolute left-0 right-0 top-full z-40 mt-[8px] opacity-0 transition-all duration-200"
      data-panel="products"
      aria-hidden="true"
    >
      <div class="mx-[16px] flex gap-[32px] rounded-[16px] bg-[rgba(22,29,37,0.9)] p-[16px] backdrop-blur-[7px]">
        <!-- On-Demand -->
        <div class="flex flex-1 flex-col gap-[16px] p-[24px]">
          <div class="flex items-center gap-[16px]">
            <img src="/images/icons/product-vod.svg" alt="" class="h-[32px] w-[32px]" aria-hidden="true" />
            <h4 class="text-h4 text-white">
              On-Demand
            </h4>
          </div>
          <p class="text-body text-white">
            From match replays to exclusive interviews, control how your content is organised, published, and monetised all from one platform.
          </p>
          <a href="/pricing" class="group inline-flex items-center gap-[8px] text-body-lg font-medium capitalize tracking-[0.32px] text-white transition-colors hover:text-yellow-tennis">
            Learn more
            <svg class="h-[16px] w-[16px] transition-transform group-hover:translate-x-[4px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <!-- Live & On-Demand -->
        <div class="flex flex-1 flex-col gap-[16px] p-[24px]">
          <div class="flex items-center gap-[16px]">
            <img src="/images/icons/product-live.svg" alt="" class="h-[24px] w-[24px]" aria-hidden="true" />
            <h4 class="text-h4 text-white">
              Live & On-Demand
            </h4>
          </div>
          <p class="text-body text-white">
            Deliver smooth, low-latency live broadcasts with professional-grade quality whether it's a packed stadium or a behind-the-scenes moment.
          </p>
          <a href="/pricing" class="group inline-flex items-center gap-[8px] text-body-lg font-medium capitalize tracking-[0.32px] text-white transition-colors hover:text-yellow-tennis">
            Learn more
            <svg class="h-[16px] w-[16px] transition-transform group-hover:translate-x-[4px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function initNavDropdowns() {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.nav-dropdown-trigger');
    const panels = document.querySelectorAll<HTMLElement>('.nav-dropdown-panel');

    function closeAll() {
      triggers.forEach((t) => {
        t.setAttribute('aria-expanded', 'false');
        t.querySelector('svg')?.classList.remove('rotate-180');
      });
      panels.forEach((p) => {
        p.classList.add('opacity-0', 'pointer-events-none');
        p.classList.remove('opacity-100', 'pointer-events-auto');
        p.setAttribute('aria-hidden', 'true');
      });
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const dropdownName = trigger.dataset.dropdown;
        const panel = document.querySelector<HTMLElement>(`[data-panel="${dropdownName}"]`);
        if (!panel) return;

        const isOpen = trigger.getAttribute('aria-expanded') === 'true';

        closeAll();

        if (!isOpen) {
          trigger.setAttribute('aria-expanded', 'true');
          trigger.querySelector('svg')?.classList.add('rotate-180');
          panel.classList.remove('opacity-0', 'pointer-events-none');
          panel.classList.add('opacity-100', 'pointer-events-auto');
          panel.setAttribute('aria-hidden', 'false');
        }
      });
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.nav-dropdown-trigger') && !target.closest('.nav-dropdown-panel')) {
        closeAll();
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAll();
    });
  }

  document.addEventListener('astro:page-load', initNavDropdowns);
  initNavDropdowns();

  function initMobileMenu() {
    const trigger = document.querySelector<HTMLButtonElement>('.mobile-menu-trigger');
    const panel = document.querySelector<HTMLElement>('.mobile-menu-panel');
    const hamburgerIcon = trigger?.querySelector<SVGElement>('.hamburger-icon');
    const closeIcon = trigger?.querySelector<SVGElement>('.close-icon');
    if (!trigger || !panel || !hamburgerIcon || !closeIcon) return;

    function setOpen(open: boolean) {
      trigger!.setAttribute('aria-expanded', String(open));
      panel!.setAttribute('aria-hidden', String(!open));
      panel!.classList.toggle('opacity-0', !open);
      panel!.classList.toggle('opacity-100', open);
      panel!.classList.toggle('pointer-events-none', !open);
      panel!.classList.toggle('pointer-events-auto', open);
      hamburgerIcon!.classList.toggle('hidden', open);
      closeIcon!.classList.toggle('hidden', !open);
      // Lock body scroll when menu is open (DEV-2271 full-viewport drawer)
      document.body.style.overflow = open ? 'hidden' : '';
    }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    // Close when clicking an <a> link inside (but not the Products toggle button)
    panel.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    // Mobile Products dropdown toggle (DEV-2270)
    const productsTrigger = panel.querySelector<HTMLButtonElement>('.mobile-products-trigger');
    const productsPanel = panel.querySelector<HTMLElement>('.mobile-products-panel');
    const productsChevron = panel.querySelector<SVGElement>('.mobile-products-chevron');
    if (productsTrigger && productsPanel && productsChevron) {
      productsTrigger.addEventListener('click', () => {
        const isOpen = productsTrigger.getAttribute('aria-expanded') === 'true';
        const next = !isOpen;
        productsTrigger.setAttribute('aria-expanded', String(next));
        productsPanel.classList.toggle('accordion-collapsed', !next);
        productsPanel.classList.toggle('accordion-expanded', next);
        productsChevron.classList.toggle('rotate-180', next);
      });
    }
  }

  document.addEventListener('astro:page-load', initMobileMenu);
  initMobileMenu();
</script>
