---
import type { Navigation } from '../../types/content';

interface Props {
  nav: Navigation;
}

const { nav } = Astro.props;

const navLinks = [
  { text: 'Products', href: '#products', hasDropdown: true },
  { text: 'Features', href: '#features', hasDropdown: false },
  { text: 'Solution', href: '#solution', hasDropdown: true },
  { text: 'Pricing', href: '#pricing', hasDropdown: false },
];
---

<header class="fixed top-0 left-0 right-0 z-50 p-[16px]">
  <nav
    class="mx-auto flex max-w-[1440px] items-center justify-between rounded-[16px] bg-[rgba(22,29,37,0.9)] px-[24px] py-[12px] backdrop-blur-[12px]"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="font-heading text-[22px] font-medium uppercase tracking-wide text-white">
      {nav.brand.name}
    </a>

    <!-- Center links -->
    <ul class="hidden items-center gap-[4px] lg:flex" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="flex items-center gap-[4px] rounded-[8px] px-[8px] py-[4px] font-body text-[16px] font-medium capitalize tracking-[-0.16px] text-white transition-colors hover:bg-white/10"
          >
            {link.text}
            {link.hasDropdown && (
              <svg
                class="h-[16px] w-[16px] opacity-70"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right buttons -->
    <div class="hidden items-center gap-[12px] lg:flex">
      <a
        href="/sign-in"
        class="rounded-[4px] border border-white px-[32px] py-[16px] font-body text-[16px] font-medium uppercase tracking-[0.32px] text-white transition-colors hover:bg-white/10"
      >
        Sign in
      </a>
      <a
        href="/book-a-call"
        class="rounded-[4px] bg-blue-matchday px-[32px] py-[16px] font-body text-[16px] font-medium uppercase tracking-[0.32px] text-white transition-colors hover:bg-blue-matchday/90"
      >
        Book a call
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      class="flex items-center justify-center rounded-[8px] p-[8px] text-white lg:hidden"
      aria-label="Open menu"
      type="button"
    >
      <svg class="h-[24px] w-[24px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>
