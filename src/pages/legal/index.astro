---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadYaml } from '../../lib/yaml-loader';
import type { LegalIndexContent, PageContent } from '../../types/content';
import CTABanner from '../../components/sections/CTABanner.astro';

const legal = await loadYaml<LegalIndexContent>('legal/_index.yaml');

const home = await loadYaml<PageContent>('pages/home.yaml');
const ctaBanner = home.sections.find((s) => s.type === 'cta_banner');

const legalWebPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: legal.page.title,
  description: legal.page.description,
  url: 'https://matchdaylive.com/legal',
  isPartOf: { '@type': 'WebSite', url: 'https://matchdaylive.com' },
};
---

<BaseLayout title={legal.page.title} description={legal.page.description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(legalWebPage)} />
  </Fragment>

  {/* Hero — white bg, left-aligned heading per DEV-2293/2296.
      Tight bottom padding (DEV-2294 round 6) so cards sit closer to heading. */}
  <section class="bg-white px-[24px] pb-[16px] pt-35 md:pb-[24px] md:pt-45 md:px-30">
    <div class="mx-auto max-w-300">
      <h1 class="text-h1 text-charcoal-pitch">{legal.hero.heading}</h1>
    </div>
  </section>

  {/* Document grid — white page bg per DEV-2294. Top padding tightened
      to reduce heading->cards gap (DEV-2294 round 6). Hover state per
      DEV-2295 round 6: whole card -> tennis-yellow, View stays charcoal. */}
  <section class="bg-white px-[24px] pb-20 pt-[24px] md:px-30 md:pb-30 md:pt-[32px]">
    <div class="mx-auto grid max-w-300 grid-cols-1 gap-[24px] md:grid-cols-2 md:gap-[32px]">
      {legal.documents.map((doc) => (
        <a
          href={`/legal/${doc.slug}`}
          class="group flex items-start justify-between gap-[24px] rounded-[16px] bg-grey p-[24px] transition-colors hover:bg-yellow-tennis md:p-[40px]"
        >
          <div class="flex flex-col gap-[12px]">
            <h2 class="text-h4 text-charcoal-pitch">{doc.title}</h2>
            <p class="text-body-lg text-text-primary">{doc.description}</p>
            <span class="mt-[8px] inline-flex w-fit items-center gap-[8px] text-body-lg font-medium text-charcoal-pitch">
              View
              <svg class="h-[16px] w-[16px] transition-transform group-hover:translate-x-[4px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {ctaBanner && ctaBanner.type === 'cta_banner' && <CTABanner section={ctaBanner} />}
</BaseLayout>
