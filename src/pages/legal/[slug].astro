---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadYaml } from '../../lib/yaml-loader';
import type {
  LegalIndexContent,
  LegalDocumentContent,
  PageContent,
} from '../../types/content';
import CTABanner from '../../components/sections/CTABanner.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  const legalIndex = await loadYaml<LegalIndexContent>('legal/_index.yaml');
  return Promise.all(
    legalIndex.documents.map(async (doc) => {
      const document = await loadYaml<LegalDocumentContent>(`legal/${doc.slug}.yaml`);
      return {
        params: { slug: doc.slug },
        props: { document },
      };
    })
  );
}

interface Props {
  document: LegalDocumentContent;
}

const { document } = Astro.props;

const home = await loadYaml<PageContent>('pages/home.yaml');
const ctaBanner = home.sections.find((s) => s.type === 'cta_banner');

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: document.title,
  description: document.page.description,
  url: `https://matchdaylive.com/legal/${document.slug}`,
  isPartOf: { '@type': 'WebSite', url: 'https://matchdaylive.com' },
  datePublished: document.lastUpdated,
  dateModified: document.lastUpdated,
  publisher: {
    '@type': 'Organization',
    name: 'Matchday Media',
    url: 'https://matchdaylive.com',
  },
};
---

<BaseLayout title={document.page.title} description={document.page.description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  {/* Hero */}
  <section class="bg-charcoal-pitch px-[24px] pb-20 pt-35 md:pb-30 md:pt-45 md:px-30">
    <div class="mx-auto flex max-w-200 flex-col gap-[16px]">
      <h1 class="text-h1 text-white">{document.title}</h1>
      <p class="text-body text-white/60">Last updated: {document.lastUpdated}</p>
    </div>
  </section>

  {/* Body */}
  <section class="bg-white px-[24px] py-20 md:px-30 md:py-30">
    <article class="legal-article mx-auto flex max-w-200 flex-col gap-[40px]">
      {document.intro && (
        <p class="text-body-lg text-text-primary">{document.intro}</p>
      )}

      {document.sections.map((section) => (
        <div class="flex flex-col gap-[16px]">
          <h2 class="text-h4 text-charcoal-pitch">{section.heading}</h2>
          <div class="legal-body text-body text-text-primary" set:html={marked.parse(section.body) as string} />
        </div>
      ))}
    </article>
  </section>

  {ctaBanner && ctaBanner.type === 'cta_banner' && <CTABanner section={ctaBanner} />}
</BaseLayout>

<style is:global>
  .legal-article .legal-body h3 {
    font-family: var(--font-subheading);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.45;
    text-transform: uppercase;
    color: var(--color-charcoal-pitch);
    margin-top: 24px;
    margin-bottom: 12px;
  }
  .legal-article .legal-body p {
    margin-bottom: 12px;
  }
  .legal-article .legal-body strong {
    color: var(--color-charcoal-pitch);
    font-weight: 600;
  }
  .legal-article .legal-body ul {
    list-style: disc;
    padding-left: 24px;
    margin-bottom: 12px;
  }
  .legal-article .legal-body ol {
    list-style: decimal;
    padding-left: 24px;
    margin-bottom: 12px;
  }
  .legal-article .legal-body li {
    margin-bottom: 6px;
  }
  .legal-article .legal-body a {
    color: var(--color-blue-matchday);
    text-decoration: underline;
  }
</style>
