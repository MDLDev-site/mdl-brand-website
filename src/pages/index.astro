---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadYaml } from '../lib/yaml-loader';
import type { PageContent } from '../types/content';
import Hero from '../components/sections/Hero.astro';
import LogoBanner from '../components/sections/LogoBanner.astro';
import Feature from '../components/sections/Feature.astro';
import Carousel from '../components/sections/Carousel.astro';
import Grid from '../components/sections/Grid.astro';
import Customers from '../components/sections/Customers.astro';
import AccordionFeatures from '../components/sections/AccordionFeatures.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import MailingList from '../components/sections/MailingList.astro';
import Diagonals from '../components/sections/Diagonals.astro';

const page = await loadYaml<PageContent>('pages/home.yaml');
---

<BaseLayout title={page.page.title} description={page.page.description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "MatchDayLive",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "Web",
      "url": "https://matchdaylive.com",
      "description": "MatchDayLive is an all-in-one white-label OTT streaming platform for sports clubs, leagues and federations. Launch branded live-streaming and on-demand channels with subscriptions, pay-per-view, fan analytics, and global CDN delivery.",
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "GBP",
        "lowPrice": "399",
        "highPrice": "1999",
        "offerCount": "8"
      },
      "featureList": [
        "White-label OTT platform on your own domain",
        "Live streaming with low latency",
        "On-demand video library",
        "Geographic content access controls",
        "Stripe-powered subscriptions and pay-per-view",
        "Fan analytics and revenue dashboards",
        "Global CDN delivery via CloudFront",
        "Chromecast and AirPlay casting",
        "GDPR-compliant data handling",
        "Fan support via Intercom"
      ],
      "provider": {
        "@type": "Organization",
        "name": "Matchday Media",
        "url": "https://matchdaylive.com"
      }
    })} />
  </Fragment>
  {page.sections.map((section) => {
    if (section.type === 'hero') {
      return <Hero section={section} />;
    } else if (section.type === 'logo_banner') {
      return <LogoBanner section={section} />;
    } else if (section.type === 'feature') {
      return <Feature section={section} />;
    } else if (section.type === 'carousel') {
      return <Carousel section={section} />;
    } else if (section.type === 'grid') {
      return <Grid section={section} />;
    } else if (section.type === 'customers') {
      return <Customers section={section} />;
    } else if (section.type === 'accordion_features') {
      return <AccordionFeatures section={section} />;
    } else if (section.type === 'cta_banner') {
      return <CTABanner section={section} />;
    } else if (section.type === 'mailing_list') {
      return <MailingList section={section} />;
    } else if (section.type === 'diagonals') {
      return <Diagonals section={section} />;
    }
    return null;
  })}
</BaseLayout>
